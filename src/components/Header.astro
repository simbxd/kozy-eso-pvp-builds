---
const currentPath = Astro.url.pathname;
const buildsActive = currentPath.startsWith('/builds');
const guidesActive = currentPath.startsWith('/guides');
---

<header>
  <div class="rail">
    <a href="/" class="brand" aria-label="Kozy ESO PvP — Home">
      <svg width="30" height="30" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <path d="M19 3 L33 19 L19 35 L5 19 Z" stroke="url(#hg)" stroke-width="1.2" fill="none"/>
        <path d="M19 9 L28 19 L19 29 L10 19 Z" stroke="#6d28d9" stroke-width="1" fill="none" opacity="0.6"/>
        <circle cx="19" cy="19" r="2.6" fill="#8b5cf6"/>
        <defs>
          <linearGradient id="hg" x1="0" y1="0" x2="0" y2="38" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#ede8ff"/>
            <stop offset="1" stop-color="#6d28d9"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="brand-name">KOZY · ESO PvP</span>
    </a>

    <nav aria-label="Main navigation">
      <a
        href="/builds"
        class:list={['nav-link', { on: buildsActive }]}
        aria-current={buildsActive ? 'page' : undefined}
      >Builds</a>
      <a
        href="/guides"
        class:list={['nav-link', { on: guidesActive }]}
        aria-current={guidesActive ? 'page' : undefined}
      >Guides</a>
      <a href="/about" class="nav-link">About</a>
    </nav>

    <div class="meta">
      PATCH U50 &nbsp;·&nbsp;
      <span class="eso-status" id="eso-status" aria-live="polite">
        <span class="eso-status__dot" id="eso-dot"></span>
        <span id="eso-label">—</span>
      </span>
    </div>
  </div>
</header>

<script>
  const ESO_URL = 'https://live-services.elderscrollsonline.com/status/realms';
  const PROXY = 'https://api.allorigins.win/get?url=' + encodeURIComponent(ESO_URL);

  async function fetchStatus() {
    const dot   = document.getElementById('eso-dot') as HTMLElement | null;
    const label = document.getElementById('eso-label') as HTMLElement | null;
    if (!dot || !label) return;

    try {
      const controller = new AbortController();
      setTimeout(() => controller.abort(), 8000);
      const res  = await fetch(PROXY, { cache: 'no-store', signal: controller.signal });
      const data = await res.json();

      // allorigins.win/get wraps response in { contents: "...", status: {} }
      const raw = data?.contents ?? data;
      const parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;
      const servers = parsed?.zos_platform_response?.response ?? {};
      const eu = servers['The Elder Scrolls Online (EU)'];

      if (eu === undefined) {
        dot.dataset.state = 'unknown';
        label.textContent = 'ESO N/A';
      } else {
        const up = eu === 'UP';
        dot.dataset.state = up ? 'online' : 'offline';
        label.textContent = up ? 'PC EU · Online' : 'PC EU · Offline';
      }
    } catch {
      dot.dataset.state = 'unknown';
      label.textContent = 'ESO N/A';
    }
  }

  fetchStatus();
  setInterval(fetchStatus, 60_000);
</script>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    position: relative;
    z-index: 10;
  }

  .rail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    max-width: 1240px;
    margin: 0 auto;
    padding: 14px 64px 16px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.28em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.34em;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--color-text); }

  nav {
    display: flex;
    gap: 22px;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 6px 2px;
    position: relative;
    transition: color 200ms;
  }
  .nav-link:hover { color: var(--color-text); }

  .on { color: var(--color-text); }
  .on::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -16px;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 14px var(--color-accent-glow);
  }

  .meta {
    text-align: right;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .eso-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .eso-status__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-text-muted);
    flex-shrink: 0;
    transition: background 400ms, box-shadow 400ms;
  }

  .eso-status__dot[data-state="online"] {
    background: #4ade80;
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.6);
  }

  .eso-status__dot[data-state="offline"] {
    background: var(--color-critical);
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.5);
  }

  @media (max-width: 760px) {
    .rail {
      flex-wrap: wrap;
      gap: 12px;
      padding: 14px 24px 22px;
    }
    .meta { display: none; }
  }
</style>
