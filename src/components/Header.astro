---
const currentPath = Astro.url.pathname;
const buildsActive = currentPath.startsWith('/builds');
const guidesActive = currentPath.startsWith('/guides');
const toolsActive = currentPath.startsWith('/tools');
---

<header>
  <div class="rail">
    <a href="/" class="brand" aria-label="Kozy ESO PvP — Home">
      <svg width="30" height="30" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <path d="M19 3 L33 19 L19 35 L5 19 Z" stroke="url(#hg)" stroke-width="1.2" fill="none"/>
        <path d="M19 9 L28 19 L19 29 L10 19 Z" stroke="#6d28d9" stroke-width="1" fill="none" opacity="0.6"/>
        <circle cx="19" cy="19" r="2.6" fill="#8b5cf6"/>
        <defs>
          <linearGradient id="hg" x1="0" y1="0" x2="0" y2="38" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#ede8ff"/>
            <stop offset="1" stop-color="#6d28d9"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="brand-name">KOZY · ESO PvP</span>
    </a>

    <nav aria-label="Main navigation">
      <a
        href="/builds"
        class:list={['nav-link', { on: buildsActive }]}
        aria-current={buildsActive ? 'page' : undefined}
      >Builds</a>
      <a
        href="/guides"
        class:list={['nav-link', { on: guidesActive }]}
        aria-current={guidesActive ? 'page' : undefined}
      >Guides</a>
      <div class="nav-dd">
        <a
          href="/tools/skill-bar-builder"
          class:list={['nav-link', 'nav-dd__trigger', { on: toolsActive }]}
          aria-current={toolsActive ? 'page' : undefined}
          aria-haspopup="true"
        >Tools</a>
        <div class="nav-dd__panel" role="menu">
          <a href="/tools/skill-bar-builder" class="nav-dd__item" role="menuitem"
            >Skill Bar Builder</a>
          <span
            class="nav-dd__item nav-dd__item--soon"
            role="menuitem"
            aria-disabled="true"
          >Build Editor <em>soon</em></span>
        </div>
      </div>
      <a href="/about" class="nav-link">About</a>
    </nav>

    <div class="meta">
      <span class="meta__patch">PATCH U50 &nbsp;·&nbsp;</span>
      <span class="eso-servers" aria-live="polite">
        <span class="srv" id="srv-eu"><span class="srv__dot"></span><span class="srv__lbl">EU</span></span>
        <span class="srv__sep">·</span>
        <span class="srv" id="srv-na"><span class="srv__dot"></span><span class="srv__lbl">NA</span></span>
        <span class="srv__sep">·</span>
        <span class="srv" id="srv-pts"><span class="srv__dot"></span><span class="srv__lbl">PTS</span></span>
      </span>
    </div>
  </div>
</header>

<script>
  const PROXY = 'https://eso-status-proxy.simbad14100.workers.dev';

  const SERVERS: Record<string, string> = {
    eu:  'The Elder Scrolls Online (EU)',
    na:  'The Elder Scrolls Online (NA)',
    pts: 'The Elder Scrolls Online (PTS)',
  };

  function applyState(id: string, status: string | undefined) {
    const el = document.getElementById(`srv-${id}`);
    if (!el) return;
    const dot = el.querySelector('.srv__dot') as HTMLElement;
    if (status === 'UP')        dot.dataset.state = 'online';
    else if (status === 'DOWN') dot.dataset.state = 'offline';
    else                        dot.dataset.state = 'unknown';
  }

  async function fetchStatus() {
    try {
      const controller = new AbortController();
      setTimeout(() => controller.abort(), 8000);
      const res     = await fetch(PROXY, { cache: 'no-store', signal: controller.signal });
      const data    = await res.json();
      const servers = data?.zos_platform_response?.response ?? {};
      Object.entries(SERVERS).forEach(([id, key]) => applyState(id, servers[key]));
    } catch {
      ['eu', 'na', 'pts'].forEach(id => applyState(id, undefined));
    }
  }

  fetchStatus();
  setInterval(fetchStatus, 60_000);
</script>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    position: relative;
    z-index: 10;
  }

  .rail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    max-width: 1240px;
    margin: 0 auto;
    padding: 14px 64px 16px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.28em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.34em;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--color-text); }

  nav {
    display: flex;
    gap: 22px;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 6px 2px;
    position: relative;
    transition: color 200ms;
  }
  .nav-link:hover { color: var(--color-text); }

  /* ── Tools dropdown (CSS-only — reveal on hover/focus-within) ── */
  .nav-dd { position: relative; }

  /* Bridges the gap between trigger and panel so the cursor can travel
     down without the panel closing (panel sits 8px below). */
  .nav-dd::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 10px;
  }

  .nav-dd__panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 188px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-radius: 6px;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.55);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms, transform 160ms;
    z-index: 20;
  }

  .nav-dd:hover .nav-dd__panel,
  .nav-dd:focus-within .nav-dd__panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dd__item {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 9px 12px;
    border-radius: 4px;
    white-space: nowrap;
    transition: color 160ms, background 160ms;
  }

  a.nav-dd__item:hover,
  a.nav-dd__item:focus-visible {
    color: var(--color-text);
    background: var(--color-bg);
  }

  .nav-dd__item--soon {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-border-2);
    cursor: default;
  }

  .nav-dd__item--soon em {
    font-style: normal;
    font-size: 8px;
    letter-spacing: 0.1em;
    color: var(--color-accent-dim);
    border: 1px solid var(--color-accent-dim);
    border-radius: 3px;
    padding: 1px 4px;
  }

  .on { color: var(--color-text); }
  .on::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -16px;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 14px var(--color-accent-glow);
  }

  .meta {
    text-align: right;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .eso-servers {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .srv {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .srv__sep { color: var(--color-border); }

  .srv__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
    flex-shrink: 0;
    transition: background 400ms, box-shadow 400ms;
  }

  .srv__dot[data-state="online"]  { background: #4ade80; box-shadow: 0 0 5px rgba(74,222,128,0.6); }
  .srv__dot[data-state="offline"] { background: var(--color-critical); box-shadow: 0 0 5px rgba(239,68,68,0.5); }

  @media (max-width: 760px) {
    .rail {
      flex-wrap: wrap;
      gap: 12px;
      padding: 14px 24px 22px;
    }
    .meta__patch { display: none; }
    .on::after { display: none; }
  }
</style>
