---
interface Props {
  type: 'formula' | 'note' | 'warning';
  label?: string;
}

const { type, label } = Astro.props;

const defaults = {
  formula: 'Formula',
  note:    'Note',
  warning: 'Warning',
};

const displayLabel = label ?? defaults[type];
---

<aside class:list={['callout', `callout--${type}`]}>
  <span class="callout__kicker">{displayLabel}</span>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    margin: 24px 0;
    padding: 18px 22px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
  }

  .callout--note    { border-left: 2px solid var(--color-accent); }
  .callout--formula { border-left: 2px solid var(--color-mythic); }
  .callout--warning { border-left: 2px solid var(--color-critical); }

  .callout__kicker {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding-top: 4px;
    min-width: 80px;
  }

  .callout--note    .callout__kicker { color: var(--color-accent); }
  .callout--formula .callout__kicker { color: var(--color-mythic); }
  .callout--warning .callout__kicker { color: var(--color-critical); }

  .callout__body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-text);
  }

  .callout__body :global(p) { margin: 0; }
  .callout__body :global(code) {
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--color-mono);
  }
</style>
