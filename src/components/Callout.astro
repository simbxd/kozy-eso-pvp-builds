---
interface Props {
  type: 'formula' | 'note' | 'warning';
  label?: string;
}

const { type, label } = Astro.props;

const defaults = {
  formula: 'Formula',
  note: 'Note',
  warning: 'Warning',
};

const displayLabel = label ?? defaults[type];
---

<aside class:list={['callout', `callout--${type}`]}>
  <span class="callout-label">{displayLabel}</span>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border-left: 3px solid;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    background-color: var(--color-surface);
    border-radius: 0 2px 2px 0;
  }

  .callout--formula {
    border-color: var(--color-mono);
    background-color: color-mix(in srgb, var(--color-mono) 8%, var(--color-surface));
  }

  .callout--note {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }

  .callout--warning {
    border-color: var(--color-critical);
    background-color: color-mix(in srgb, var(--color-critical) 8%, var(--color-surface));
  }

  .callout-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.4rem;
  }

  .callout--formula .callout-label { color: var(--color-mono); }
  .callout--note .callout-label    { color: var(--color-accent); }
  .callout--warning .callout-label { color: var(--color-critical); }

  .callout-body {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .callout-body :global(p) { margin: 0; }
  .callout-body :global(code) { font-size: 0.85em; }
</style>
