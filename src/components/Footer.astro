<footer class="kz-colophon">
  <div class="kz-colophon__l">
    <svg width="32" height="32" viewBox="0 0 38 38" fill="none" aria-hidden="true">
      <path d="M19 3 L33 19 L19 35 L5 19 Z" stroke="url(#fg)" stroke-width="1.2" fill="none"/>
      <path d="M19 9 L28 19 L19 29 L10 19 Z" stroke="#6d28d9" stroke-width="1" fill="none" opacity="0.6"/>
      <circle cx="19" cy="19" r="2.6" fill="#8b5cf6"/>
      <defs>
        <linearGradient id="fg" x1="0" y1="0" x2="0" y2="38" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#ede8ff"/>
          <stop offset="1" stop-color="#6d28d9"/>
        </linearGradient>
      </defs>
    </svg>
    <div>
      <div class="kz-colophon__title">Kozy ESO</div>
      <div class="kz-colophon__sub">Builds, guides, mechanics — for the open world.</div>
    </div>
  </div>

  <div class="kz-colophon__r">
    <span>PATCH U50</span>
    <span>·</span>
    <span>Set data: <a href="https://en.uesp.net/wiki/Online:Online" target="_blank" rel="noopener noreferrer">UESP</a> CC-BY-SA</span>
  </div>
</footer>

<style>
  .kz-colophon {
    margin-top: 96px;
    padding-top: 28px;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .kz-colophon__l {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .kz-colophon__title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-text);
  }

  .kz-colophon__sub {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 13.5px;
    color: var(--color-text-muted);
  }

  .kz-colophon__r {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .kz-colophon__r a {
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-2);
  }
  .kz-colophon__r a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .kz-colophon {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
