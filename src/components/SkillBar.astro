---
interface Skill {
  id: string;
  name: string;
  base_skill?: string | null;
  morph_of?: string | null;
  morph_sibling?: string | null;
  morph_sibling_name?: string | null;
  morph_rationale?: string | null;
  class: string;
  skill_line: string;
  type: string;
  resource?: string;
  icon?: string;
  scribing?: { focus: string; signature: string; affix: string } | null;
}

interface Props {
  bar1Skills: Skill[];
  bar2Skills: Skill[];
}

const { bar1Skills, bar2Skills } = Astro.props;

const bars = [
  { num: 'I',  label: 'Front Bar', skills: bar1Skills },
  { num: 'II', label: 'Back Bar',  skills: bar2Skills },
];

function slotIndex(i: number) {
  return String(i + 1).padStart(2, '0');
}
---

<div class="bars-wrap" data-kz-bars>
  <div class="bars__toggle">
    <button class="tab tab--on" data-bar-tab aria-pressed="true">
      <span class="tab__num">I</span>
      <span class="tab__label">Front Bar</span>
    </button>
    <button class="tab" data-bar-tab aria-pressed="false">
      <span class="tab__num">II</span>
      <span class="tab__label">Back Bar</span>
    </button>
    <div class="tab__indicator" data-bar-indicator aria-hidden="true"></div>
  </div>

  {bars.map(({ skills }, barIdx) => (
    <div class="bars__row" data-bar-row hidden={barIdx !== 0 || undefined}>
      {skills.map((skill, i) => {
        const isUlt       = i === 5;
        const hasImg      = !!skill.icon;
        const hasMorph    = !!skill.morph_of;
        const hasScribing = !!skill.scribing;

        return (
          <div
            class:list={['slot', isUlt && 'slot--ult']}
            tabindex="0"
            data-id={skill.id}
            role="button"
            aria-label={skill.name}
          >
            <div class="slot__index">{slotIndex(i)}</div>

            <div class="slot__icon">
              {hasImg
                ? <img class="slot__img" src={skill.icon} alt={skill.name} width="48" height="48" loading="lazy" />
                : <span class="slot__glyph">{isUlt ? '◆' : skill.name[0]}</span>
              }
              <div class="slot__cls" aria-hidden="true"></div>
            </div>

            <div class="slot__name">{skill.name}</div>
            <div class="slot__line">{skill.skill_line.toUpperCase()}</div>

            {(hasMorph || hasScribing) && (
              <div class="tooltip" role="tooltip">
                <div class="tooltip__head">
                  <div class="tooltip__title">{skill.name}</div>
                  <div class="tooltip__meta">
                    <span class="tooltip__line">{skill.skill_line.toUpperCase()}</span>
                    <div class="tooltip__tags">
                      {hasScribing && <span class="tag tag--scribing">Scribed</span>}
                      <span class:list={['tag', `tag--${skill.type.toLowerCase()}`]}>{skill.type}</span>
                      {skill.resource && skill.resource !== 'None' && (
                        <span class:list={['tag', `tag--${skill.resource.toLowerCase()}`]}>{skill.resource}</span>
                      )}
                    </div>
                  </div>
                </div>

                {hasMorph && (
                  <div class="morph">
                    <span class="morph__base">{skill.base_skill}</span>
                    <span class="morph__arrow">→</span>
                    <span class="morph__chosen">{skill.name}</span>
                    {skill.morph_sibling_name && (
                      <>
                        <span class="morph__or">/</span>
                        <span class="morph__sibling">{skill.morph_sibling_name}</span>
                      </>
                    )}
                  </div>
                )}

                {hasScribing && skill.scribing && (
                  <div class="scripts">
                    <div class="scripts__row">
                      <span class="scripts__k">Focus</span>
                      <span class="scripts__v">{skill.scribing.focus}</span>
                    </div>
                    <div class="scripts__row">
                      <span class="scripts__k">Signature</span>
                      <span class="scripts__v">{skill.scribing.signature}</span>
                    </div>
                    <div class="scripts__row">
                      <span class="scripts__k">Affix</span>
                      <span class="scripts__v">{skill.scribing.affix}</span>
                    </div>
                  </div>
                )}

                {skill.morph_rationale && (
                  <p class="tooltip__rationale">{skill.morph_rationale}</p>
                )}
              </div>
            )}
          </div>
        );
      })}
    </div>
  ))}
</div>

<script is:inline>
  document.querySelectorAll('[data-kz-bars]').forEach(function(wrap) {
    var tabs      = wrap.querySelectorAll('[data-bar-tab]');
    var rows      = wrap.querySelectorAll('[data-bar-row]');
    var indicator = wrap.querySelector('[data-bar-indicator]');

    tabs.forEach(function(tab, i) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) {
          t.classList.remove('tab--on');
          t.setAttribute('aria-pressed', 'false');
        });
        tab.classList.add('tab--on');
        tab.setAttribute('aria-pressed', 'true');
        rows.forEach(function(row, j) {
          if (j === i) row.removeAttribute('hidden');
          else row.setAttribute('hidden', '');
        });
        indicator.style.transform = i === 0 ? 'translateX(0)' : 'translateX(100%)';
      });
    });
  });
</script>

<style>
  .bars-wrap {
    position: relative;
    z-index: 10;
  }

  /* Toggle */
  .bars__toggle {
    position: relative;
    display: inline-flex;
    gap: 0;
    border: 1px solid var(--color-border-2);
    background: var(--color-surface);
    padding: 0;
    margin-bottom: 36px;
    overflow: hidden;
  }

  .tab {
    position: relative;
    z-index: 1;
    appearance: none;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 13px 28px 13px 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: color 200ms;
  }
  .tab:hover { color: var(--color-text); }

  .tab__num {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    transition: color 200ms;
  }

  .tab__label {
    font-family: var(--font-display);
    font-size: 20px;
    font-style: italic;
    font-weight: 500;
    white-space: nowrap;
  }

  .tab--on { color: var(--color-text); }
  .tab--on .tab__num { color: var(--color-accent); }

  .tab__indicator {
    position: absolute;
    bottom: 0; left: 0;
    width: 50%;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 16px var(--color-accent-glow);
    transition: transform 360ms cubic-bezier(.6,.05,.2,1);
    z-index: 0;
  }

  /* Bar row */
  .bars__row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    padding: 28px 24px;
    background:
      linear-gradient(180deg, rgba(139,92,246,0.04), rgba(0,0,0,0)),
      var(--color-surface);
    border: 1px solid var(--color-border-2);
    position: relative;
    animation: kz-fade 380ms cubic-bezier(.2,.7,.2,1);
  }

  .bars__row::before,
  .bars__row::after {
    content: '';
    position: absolute;
    left: 24px; right: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-2) 20%, var(--color-border-2) 80%, transparent);
  }
  .bars__row::before { top: 0; }
  .bars__row::after  { bottom: 0; }

  @keyframes kz-fade {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Slot */
  .slot {
    position: relative;
    padding: 14px 14px 16px;
    cursor: pointer;
    transition: transform 220ms, background 220ms;
    outline: none;
  }

  .slot:hover,
  .slot:focus-visible {
    background: var(--color-surface-2);
    transform: translateY(-2px);
  }

  .slot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .slot__index {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.32em;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .slot--ult .slot__index { color: var(--color-mythic); }

  /* Icon frame */
  .slot__icon {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background:
      radial-gradient(ellipse at 50% 40%, rgba(139,92,246,0.06), transparent 75%),
      linear-gradient(160deg, #1a1729 0%, #0c0a17 100%);
    border: 1px solid var(--color-border-2);
    display: grid;
    place-items: center;
    margin-bottom: 12px;
    overflow: hidden;
    box-shadow: inset 0 0 24px rgba(0,0,0,0.55);
    transition: border-color 260ms, box-shadow 260ms;
  }

  .slot:hover .slot__icon,
  .slot:focus-visible .slot__icon {
    border-color: #3a3358;
    box-shadow: 0 0 18px rgba(139,92,246,0.10), inset 0 0 18px rgba(139,92,246,0.06);
  }

  .slot--ult .slot__icon {
    border-color: var(--color-mythic-dim);
    background:
      radial-gradient(ellipse at 50% 30%, rgba(212,164,74,0.18), transparent 70%),
      linear-gradient(160deg, #1f1a14 0%, #0c0a06 100%);
  }

  .slot__img {
    position: relative;
    z-index: 2;
    width: 82%;
    height: 82%;
    object-fit: contain;
    filter: saturate(0.9) brightness(0.94) contrast(1.02);
    opacity: 0.96;
    transition: filter 260ms, transform 260ms, opacity 260ms;
  }

  .slot:hover .slot__img,
  .slot:focus-visible .slot__img {
    filter: saturate(1.05) brightness(1.05) contrast(1.04);
    transform: scale(1.04);
    opacity: 1;
  }

  .slot__glyph {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 40px;
    color: var(--color-text);
    letter-spacing: 0.04em;
    text-shadow: 0 0 18px var(--color-accent-glow);
    position: relative;
    z-index: 2;
  }

  .slot--ult .slot__glyph { color: var(--color-mythic); }

  .slot__cls {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255,255,255,0.025) 0%, transparent 25%, transparent 75%, rgba(0,0,0,0.18) 100%);
  }

  .slot__name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 4px;
    min-height: 36px;
  }

  .slot__line {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  /* Tooltip */
  .tooltip {
    display: none;
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border-2);
    border-top: 1px solid var(--color-accent);
    padding: 18px 18px 16px;
    z-index: 50;
    box-shadow: 0 24px 60px rgba(0,0,0,0.6), 0 0 24px var(--color-accent-glow);
    pointer-events: none;
    text-align: left;
    animation: kz-tooltip-in 180ms cubic-bezier(.2,.7,.2,1);
  }

  .tooltip::after {
    content: '';
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: var(--color-surface-2);
    border-left: 1px solid var(--color-accent);
    border-top: 1px solid var(--color-accent);
  }

  @keyframes kz-tooltip-in {
    from { opacity: 0; transform: translateX(-50%) translateY(4px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .slot:hover .tooltip,
  .slot:focus-within .tooltip { display: block; }

  /* Flip last slots to avoid overflow */
  .slot:nth-child(5) .tooltip,
  .slot:nth-child(6) .tooltip {
    left: auto;
    right: 0;
    transform: none;
    animation: kz-tooltip-in-r 180ms cubic-bezier(.2,.7,.2,1);
  }

  .slot:nth-child(5) .tooltip::after,
  .slot:nth-child(6) .tooltip::after {
    left: auto;
    right: 24px;
    transform: rotate(45deg);
  }

  @keyframes kz-tooltip-in-r {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Flip slots 1-2 to avoid left-edge overflow */
  .slot:nth-child(1) .tooltip,
  .slot:nth-child(2) .tooltip {
    left: 0;
    right: auto;
    transform: none;
    animation: kz-tooltip-in-l 180ms cubic-bezier(.2,.7,.2,1);
  }

  .slot:nth-child(1) .tooltip::after,
  .slot:nth-child(2) .tooltip::after {
    left: 24px;
    right: auto;
    transform: rotate(45deg);
  }

  @keyframes kz-tooltip-in-l {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tooltip__head {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 10px;
    margin-bottom: 12px;
  }

  .tooltip__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .tooltip__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .tooltip__line {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.22em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .tooltip__tags {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 6px;
    border: 1px solid var(--color-border-2);
    color: var(--color-text-muted);
  }

  .tag--active   { color: var(--color-mono);    border-color: rgba(196,181,253,0.25); }
  .tag--ultimate { color: var(--color-mythic);  border-color: rgba(212,164,74,0.3); }
  .tag--passive  { color: var(--color-text-muted); }
  .tag--magicka  { color: #a78bfa; border-color: rgba(167,139,250,0.25); }
  .tag--stamina  { color: #86efac; border-color: rgba(134,239,172,0.25); }
  .tag--health   { color: #fca5a5; border-color: rgba(252,165,165,0.25); }
  .tag--ultimate-resource { display: none; }
  .tag--scribing { color: var(--color-mythic); border-color: rgba(212,164,74,0.35); }

  /* Morph chain */
  .morph {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    padding: 8px 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    margin-bottom: 12px;
  }

  .morph__base  { color: var(--color-text-muted); }
  .morph__arrow { color: var(--color-accent); }

  .morph__chosen {
    color: var(--color-mono);
    background: rgba(139,92,246,0.12);
    padding: 1px 6px;
  }

  .morph__or      { color: var(--color-text-muted); opacity: 0.5; }
  .morph__sibling {
    color: var(--color-text-muted);
    text-decoration: line-through;
    text-decoration-color: rgba(125,119,160,0.4);
  }

  .morph--none {
    justify-content: center;
    color: var(--color-text-muted);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  /* Scribing scripts */
  .scripts {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    margin-bottom: 12px;
  }

  .scripts__row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .scripts__k {
    flex-shrink: 0;
    width: 64px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .scripts__v {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--color-mono);
  }

  .tooltip__rationale {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: #d8d2f0;
    margin: 0;
  }

  /* Mobile: 3-column layout */
  @media (max-width: 640px) {
    .bars__row {
      grid-template-columns: repeat(3, 1fr);
      padding: 20px 16px;
    }

    /* Tooltip max width on small screens */
    .tooltip {
      width: min(320px, calc(100vw - 48px));
    }

    /* In 3-col: col positions are 1,2,3 / 4,5,6
       Left col  (1,4): left-align  — slot 4 needs fix, slot 1 already done
       Center col (2,5): reset to center — slot 2 was left-aligned for desktop
       Right col  (3,6): right-align — slot 3 needs fix, slot 6 already done  */

    .slot:nth-child(2) .tooltip {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      animation: kz-tooltip-in 180ms cubic-bezier(.2,.7,.2,1);
    }
    .slot:nth-child(2) .tooltip::after {
      left: 50%;
      right: auto;
      transform: translateX(-50%) rotate(45deg);
    }

    .slot:nth-child(3) .tooltip {
      left: auto;
      right: 0;
      transform: none;
      animation: kz-tooltip-in-r 180ms cubic-bezier(.2,.7,.2,1);
    }
    .slot:nth-child(3) .tooltip::after {
      left: auto;
      right: 24px;
      transform: rotate(45deg);
    }

    .slot:nth-child(4) .tooltip {
      left: 0;
      right: auto;
      transform: none;
      animation: kz-tooltip-in-l 180ms cubic-bezier(.2,.7,.2,1);
    }
    .slot:nth-child(4) .tooltip::after {
      left: 24px;
      right: auto;
      transform: rotate(45deg);
    }

    .slot:nth-child(5) .tooltip {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      animation: kz-tooltip-in 180ms cubic-bezier(.2,.7,.2,1);
    }
    .slot:nth-child(5) .tooltip::after {
      left: 50%;
      right: auto;
      transform: translateX(-50%) rotate(45deg);
    }
  }
</style>
