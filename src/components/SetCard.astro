---
interface Bonus {
  count: number;
  stat: string;
  value: number | string;
}

interface Props {
  id: string;
  index?: number;
  name: string;
  type: string;
  acquisition: string;
  location: string;
  dlc: string;
  pieces: number;
  bonuses: Bonus[];
  activePieces?: number;
  role?: string;
  uesp_url: string;
  esohub_url: string;
}

const {
  id, index, name, type, acquisition, location, dlc,
  pieces, bonuses, activePieces = pieces, role,
  uesp_url, esohub_url,
} = Astro.props;

const isMythic  = type === 'Mythic';
const isMonster = type === 'Monster';

const variantClass = isMythic ? 'set--mythic' : isMonster ? 'set--monster' : '';

const idxLabel = index !== undefined ? String(index).padStart(2, '0') : '––';

const acqLabel: Record<string, string> = {
  Overland: 'OVERLAND',
  Dungeon:  'DUNGEON',
  Trial:    'TRIAL',
  PvP:      'PVP',
  Crafted:  'CRAFTED',
  Mythic:   'LEAD HUNT',
  Monster:  'DUNGEON',
  Arena:    'ARENA',
};

// 5-pip ladder — always 5 pips regardless of set max pieces
const MAX_PIPS = 5;
const pips = Array.from({ length: MAX_PIPS }, (_, i) => i < activePieces);
---

<div class:list={['set', variantClass]} data-id={id}>
  <div class="set__head">
    <div class="set__index">{idxLabel}</div>

    <div>
      <div class="set__name">{name}</div>
      <div class="set__line">
        <span>{type.toUpperCase()}</span>
        <span>·</span>
        <span>{acqLabel[acquisition] ?? acquisition.toUpperCase()}</span>
        <span>·</span>
        <span>{location}</span>
      </div>
    </div>

    <div class="set__pieces">
      <div class="set__num">{activePieces}</div>
      <span class="set__den">/ {pieces} pc</span>
    </div>
  </div>

  <div class="ladder__pips">
    {pips.map(on => (
      <div class:list={['pip', on ? 'pip--on' : 'pip--off']}></div>
    ))}
  </div>

  <ul class="ladder__list">
    {bonuses.map(b => (
      <li class:list={['bonus', b.count <= activePieces ? 'bonus--on' : '']}>
        <span class="bonus__n">{b.count}</span>
        <span class="bonus__stat">{b.stat}</span>
        <span class="bonus__val">{b.value}</span>
      </li>
    ))}
  </ul>

  {role && <p class="set__role">{role}</p>}

  <div class="set__links">
    <a href={uesp_url} target="_blank" rel="noopener noreferrer">UESP ↗</a>
    <a href={esohub_url} target="_blank" rel="noopener noreferrer">ESO Hub ↗</a>
  </div>
</div>

<style>
  .set {
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    padding: 22px 24px;
    position: relative;
  }

  .set--monster { border-top: 1px solid var(--color-accent); }
  .set--mythic {
    border-top: 1px solid var(--color-mythic);
    background: linear-gradient(180deg, rgba(212,164,74,0.04), var(--color-surface));
  }

  .set__head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: 16px;
    padding-bottom: 18px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--color-border);
  }

  .set__index {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    padding-top: 8px;
  }

  .set__name {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-text);
  }
  .set--mythic .set__name { color: var(--color-mythic); }

  .set__line {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-top: 6px;
  }

  .set__pieces {
    text-align: right;
    font-family: var(--font-display);
    line-height: 1;
  }

  .set__num {
    font-size: 42px;
    font-weight: 500;
    color: var(--color-mono);
  }
  .set--mythic .set__num { color: var(--color-mythic); }

  .set__den {
    display: block;
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  /* 5-pip ladder */
  .ladder__pips {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
    margin-bottom: 16px;
  }

  .pip {
    height: 4px;
  }

  .pip--on {
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent-glow);
  }
  .set--mythic .pip--on {
    background: var(--color-mythic);
    box-shadow: 0 0 12px rgba(212,164,74,0.3);
  }

  .pip--off {
    background: transparent;
    border-bottom: 1px dashed var(--color-border);
  }

  /* Bonus list */
  .ladder__list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
  }

  .bonus {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: baseline;
    gap: 14px;
    padding: 7px 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.4;
  }
  .bonus:last-child { border-bottom: none; }

  .bonus__n {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    text-align: right;
  }

  .bonus__stat { color: var(--color-text-muted); }

  .bonus__val {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .bonus--on .bonus__n  { color: var(--color-accent); }
  .bonus--on .bonus__stat { color: var(--color-text); }
  .bonus--on .bonus__val  { color: var(--color-mono); }

  .set--mythic .bonus--on .bonus__n,
  .set--mythic .bonus--on .bonus__val { color: var(--color-mythic); }

  /* Role line */
  .set__role {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16.5px;
    line-height: 1.45;
    color: #d8d2f0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 14px;
    margin-bottom: 16px;
  }

  /* Links */
  .set__links {
    display: flex;
    gap: 14px;
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
  }

  .set__links a {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-2);
    transition: color 150ms, border-color 150ms;
  }
  .set__links a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>
