---
interface Props {
  title: string;
  slug: string;
  class: string;
  role: string;
  resource: string;
  gamemode: string[];
  patch: string;
  difficulty: string;
  summary: string;
  featured?: boolean;
  index?: number;
  setsLine?: string;
}

const {
  title, slug, class: esClass, role, resource,
  gamemode, patch, difficulty, summary, featured,
  index, setsLine,
} = Astro.props;

const gmLabel = gamemode.length === 1 ? gamemode[0] : 'PvP';
const meta = `${resource.toUpperCase()} ${esClass.toUpperCase()} · ${gmLabel.toUpperCase()}`;
const idxLabel = index !== undefined ? String(index).padStart(2, '0') : undefined;
---

<a
  href={`/builds/${slug}`}
  class:list={['bcard', { 'bcard--featured': featured }]}
  aria-label={`Open build: ${title}`}
>
  <div class="bcard__top">
    {idxLabel && <span class="bcard__idx">{idxLabel}</span>}
    <span class="bcard__meta" title={meta}>{meta}</span>
  </div>

  <div class="bcard__name">{title}</div>

  {setsLine && (
    <>
      <div class="bcard__rule"></div>
      <div class="bcard__sets">{setsLine}</div>
    </>
  )}

  <div class="bcard__rule"></div>
  <div class="bcard__foot">
    <span><strong>PATCH</strong> {patch}</span>
    <span><strong>{difficulty.slice(0, 3).toUpperCase()}</strong></span>
    <span><strong>{role.toUpperCase()}</strong></span>
  </div>
</a>

<style>
  .bcard {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    padding: 20px 26px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: background 200ms, transform 200ms, border-color 200ms;
  }

  .bcard::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent-glow);
    transform: translateX(-3px);
    transition: transform 220ms;
  }

  .bcard:hover {
    background: var(--color-surface-2);
    border-color: #34304d;
    transform: translateY(-2px);
  }
  .bcard:hover::before { transform: translateX(0); }

  .bcard--featured { border-top: 1px solid var(--color-accent); }

  .bcard__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    overflow: hidden;
  }

  .bcard__meta {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bcard__idx { color: var(--color-accent); }

  .bcard__name {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 500;
    line-height: 1.0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background: linear-gradient(180deg, #ffffff 0%, #c4b5fd 110%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 10px;
  }

  .bcard__tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: #d8d2f0;
    line-height: 1.3;
    margin-bottom: 18px;
  }

  .bcard__rule {
    height: 1px;
    background: var(--color-border);
    margin: 0 -24px 14px;
  }

  .bcard__sets {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-mono);
    margin-bottom: 14px;
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bcard__foot {
    display: flex;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .bcard__foot span {
    display: inline-flex;
    gap: 6px;
  }

  .bcard__foot strong {
    color: var(--color-text);
    font-weight: 400;
  }
</style>
