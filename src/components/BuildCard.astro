---
interface Props {
  title: string;
  slug: string;
  class: string;
  role: string;
  resource: string;
  gamemode: string[];
  patch: string;
  difficulty: string;
  summary?: string;
  patch?: string;
  featured?: boolean;
  index?: number;
  setsLine?: string;
  subclass?: boolean;
  playstyle_tag?: string;
}

const {
  title, slug, class: esClass, role, resource,
  gamemode, patch, difficulty, summary,
  featured, index, setsLine, subclass, playstyle_tag,
} = Astro.props;

const CLASS_ABBR: Record<string, string> = {
  Dragonknight: 'DK', Sorcerer: 'Sorc', Nightblade: 'NB',
  Templar: 'Temp', Warden: 'Ward', Necromancer: 'Necro',
  Arcanist: 'Arc', Werewolf: 'WW',
};

const CLASS_COLOR: Record<string, string> = {
  Dragonknight: '#e05c3a',
  Sorcerer:     '#5b8fd6',
  Nightblade:   '#9b59b6',
  Templar:      '#d4a44a',
  Warden:       '#5ebd6a',
  Necromancer:  '#7ecac0',
  Arcanist:     '#3cb371',
  Werewolf:     '#c0792b',
};

const GM_SHORT: Record<string, string> = { 'Cyrodiil / Imperial City': 'Openworld' };
const gmLabel = gamemode.length === 1 ? (GM_SHORT[gamemode[0]] ?? gamemode[0]) : 'PvP';
const meta = `${resource.toUpperCase()} ${CLASS_ABBR[esClass] ?? esClass} · ${gmLabel.toUpperCase()}`;
const idxLabel = index !== undefined ? String(index).padStart(2, '0') : undefined;
const clsColor = CLASS_COLOR[esClass] ?? 'var(--color-accent)';
---

<a
  href={`/builds/${slug}`}
  class:list={['bcard', { 'bcard--featured': featured }]}
  aria-label={`Open build: ${title}`}
  style={`--cls-clr: ${clsColor};`}
>
  <div class="bcard__top">
    {idxLabel && <span class="bcard__idx">{idxLabel}</span>}
    <span class="bcard__meta" title={meta}>{meta}</span>
  </div>

  <div class="bcard__name">{title}</div>

  {setsLine && (
    <>
      <div class="bcard__rule"></div>
      <div class="bcard__sets">{setsLine}</div>
    </>
  )}

  <div class="bcard__rule"></div>
  <div class="bcard__foot">
    {playstyle_tag
      ? <span class="bcard__weapons">{playstyle_tag}</span>
      : <span></span>
    }
    <div class="bcard__foot-right">
      {patch && <span class="bcard__patch">{patch}</span>}
      <span class="bcard__subclass">{subclass ? 'Subclass' : 'Pureclass'}</span>
      <span class="bcard__diff">{difficulty}</span>
    </div>
  </div>
</a>

<style>
  .bcard {
    --cls-clr: var(--color-accent);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-top: 2px solid var(--cls-clr);
    padding: 20px 26px;
    position: relative;
    /* overflow: hidden retiré — il clippait le box-shadow de ::before
       et le translateY(-2px) hover sur mobile. La barre ::before utilise
       maintenant scaleX qui ne déborde jamais hors de la carte. */
    text-decoration: none;
    color: var(--color-text);
    transition: background 200ms, transform 200ms, border-color 200ms;
  }

  .bcard::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--cls-clr);
    box-shadow: 0 0 14px color-mix(in srgb, var(--cls-clr) 40%, transparent);
    /* scaleX(0 → 1) : la barre part de 0 largeur, pas de débordement
       → plus besoin d'overflow: hidden sur la carte parente */
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 220ms;
  }

  .bcard:hover {
    background: var(--color-surface-2);
    border-color: var(--cls-clr);
    transform: translateY(-2px);
  }
  .bcard:hover::before { transform: scaleX(1); }

  .bcard--featured {
    background: color-mix(in srgb, var(--cls-clr) 5%, var(--color-surface));
  }

  .bcard__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 16px;
    overflow: hidden;
  }

  .bcard__meta {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bcard__idx { color: var(--cls-clr); }

  .bcard__name {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 500;
    line-height: 1.0;
    padding-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 700;
    font-style: italic;
    background: linear-gradient(180deg, #ffffff 0%, #c4b5fd 110%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 10px;
  }

  .bcard__tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: #d8d2f0;
    line-height: 1.3;
    margin-bottom: 18px;
  }

  .bcard__rule {
    height: 1px;
    background: var(--color-border);
    margin: 0 -24px 14px;
  }

  .bcard__sets {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--color-mono);
    margin-bottom: 14px;
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bcard__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .bcard__weapons {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-text);
    font-size: 11px;
  }

  .bcard__foot-right {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }

  .bcard__patch {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .bcard__subclass {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--cls-clr);
    padding: 1px 5px;
    line-height: 1.6;
  }

  .bcard__diff {
    flex-shrink: 0;
    color: var(--cls-clr);
    font-size: 12px;
  }
</style>
