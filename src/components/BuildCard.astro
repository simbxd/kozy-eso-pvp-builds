---
interface Props {
  title: string;
  slug: string;
  class: string;
  role: string;
  resource: string;
  gamemode: string;
  patch: string;
  difficulty: string;
  summary: string;
  featured?: boolean;
}

const { title, slug, class: esClass, role, resource, gamemode, patch, difficulty, summary, featured } = Astro.props;

const resourceColors: Record<string, string> = {
  Stamina: '#8a6f3a',
  Magicka: '#4a6f9a',
  Hybrid: '#6a5a8a',
};
---

<article class:list={['build-card', { 'build-card--featured': featured }]}>
  <a href={`/builds/${slug}`} class="build-card-link">
    <div class="build-card-header">
      <span class="build-card-class">{esClass}</span>
      {featured && <span class="build-card-featured-badge">Featured</span>}
    </div>

    <h2 class="build-card-title">{title}</h2>
    <p class="build-card-summary">{summary}</p>

    <div class="build-card-tags">
      <span class="tag tag--role">{role}</span>
      <span class="tag tag--resource" style={`--resource-color: ${resourceColors[resource] ?? '#8a7f70'}`}>
        {resource}
      </span>
      <span class="tag">{gamemode}</span>
      <span class="tag">{difficulty}</span>
    </div>

    <div class="build-card-footer">
      <span class="build-card-patch">{patch}</span>
    </div>
  </a>
</article>

<style>
  .build-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    transition: border-color 0.15s;
  }

  .build-card:hover {
    border-color: var(--color-accent-dim);
  }

  .build-card--featured {
    border-color: var(--color-accent-dim);
  }

  .build-card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .build-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .build-card-class {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .build-card-featured-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .build-card-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .build-card-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .build-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    color: var(--color-text-muted);
  }

  .tag--resource {
    border-color: var(--resource-color);
    color: var(--resource-color);
  }

  .tag--role {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
  }

  .build-card-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }

  .build-card-patch {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }
</style>
