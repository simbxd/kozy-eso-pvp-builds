---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BuildCard from '../../components/BuildCard.astro';

const allBuilds = await getCollection('builds');
const sorted = allBuilds.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});

const classes = [
  'Dragonknight',
  'Sorcerer',
  'Nightblade',
  'Templar',
  'Warden',
  'Necromancer',
  'Arcanist',
];

const buildCountByClass = Object.fromEntries(
  classes.map(c => [c, allBuilds.filter(b => b.data.class === c).length])
);
---

<Base title="Builds" description="All Kozy ESO PvP builds — Stamina, Magicka, all classes.">
  <div class="page-wrap">
    <header class="page-header">
      <h1 class="page-title">Builds</h1>
      <p class="page-desc">Optimized PvP builds with gear, skills, and rotation breakdowns.</p>
    </header>

    <nav class="class-nav" aria-label="Browse builds by class">
      <div class="class-grid">
        {classes.map(c => (
          <a
            href={`/builds/class/${c.toLowerCase()}`}
            class="class-pill"
            aria-label={`${c} builds`}
          >
            <span class="class-pill-name">{c}</span>
            <span class="class-pill-count">{buildCountByClass[c]}</span>
          </a>
        ))}
        <a href="/builds/subclass" class="class-pill class-pill--subclass" aria-label="Subclass builds">
          <span class="class-pill-name">Subclass</span>
          <span class="class-pill-count class-pill-count--new">New</span>
        </a>
      </div>
    </nav>

    <div class="builds-grid">
      {sorted.map(build => (
        <BuildCard
          title={build.data.title}
          slug={build.id}
          class={build.data.class}
          role={build.data.role}
          resource={build.data.resource}
          gamemode={build.data.gamemode}
          patch={build.data.patch}
          difficulty={build.data.difficulty}
          summary={build.data.summary}
          featured={build.data.featured}
        />
      ))}
    </div>
  </div>
</Base>

<style>
  .page-wrap {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .page-desc { color: var(--color-text-muted); margin: 0; }

  /* Class nav */
  .class-nav {
    margin-bottom: 2.5rem;
  }

  .class-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .class-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.15s, background-color 0.15s;
  }

  .class-pill:hover {
    border-color: var(--color-accent-dim);
    background-color: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
  }

  .class-pill--subclass {
    border-style: dashed;
  }

  .class-pill--subclass:hover {
    border-style: solid;
  }

  .class-pill-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .class-pill-count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-bg);
    background-color: var(--color-text-muted);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
    min-width: 1.2rem;
    text-align: center;
    line-height: 1.5;
  }

  .class-pill-count--new {
    background-color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  /* Builds grid */
  .builds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: 1rem;
  }
</style>
