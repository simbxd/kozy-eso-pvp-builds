---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BuildCard from '../../components/BuildCard.astro';
import TwitchEmbed from '../../components/TwitchEmbed.astro';

const allBuilds = await getCollection('builds');
const sorted = allBuilds.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});

const classes = ['Dragonknight', 'Sorcerer', 'Nightblade', 'Templar', 'Warden', 'Necromancer', 'Arcanist', 'Werewolf'];
const countByClass = Object.fromEntries(
  classes.map(c => [c, allBuilds.filter(b => b.data.class === c).length])
);
---

<Base title="Builds" description="All Kozy ESO PvP builds — Stamina, Magicka, and Hybrid for every class.">
  <div class="bi">

    <header class="bi__head">
      <div class="bi__rail">
        <span class="bi__eyebrow">KOZY · ESO PvP</span>
        <span class="bi__count">{allBuilds.length} BUILD{allBuilds.length !== 1 ? 'S' : ''}</span>
      </div>
      <h1 class="bi__title">Builds</h1>
      <p class="bi__dek">Optimized PvP builds with gear, skills, and rotation breakdowns.</p>
    </header>

    <div class="bi__rule" aria-hidden="true">
      <div class="bi__rule-l"></div>
      <span class="bi__rule-lbl">BROWSE BY CLASS</span>
      <div class="bi__rule-l"></div>
    </div>

    <nav class="bi__cls-nav" aria-label="Browse builds by class">
      <a href="/builds" class="bi__cls-pill bi__cls-pill--all on" aria-current="page">
        <span class="bi__cls-name">ALL</span>
        <span class="bi__cls-ct">{allBuilds.length}</span>
      </a>
      {classes.map(c => (
        <a
          href={`/builds/class/${c.toLowerCase()}`}
          class="bi__cls-pill"
          aria-label={`${c} builds (${countByClass[c]})`}
        >
          <span class="bi__cls-name">{c}</span>
          <span class="bi__cls-ct">{countByClass[c]}</span>
        </a>
      ))}
    </nav>

    <div class="bi__grid">
      {sorted.map((build, i) => (
        <BuildCard
          title={build.data.title}
          slug={build.id}
          class={build.data.class}
          role={build.data.role}
          resource={build.data.resource}
          gamemode={build.data.gamemode}
          patch={build.data.patch}
          difficulty={build.data.difficulty}
          summary={build.data.summary}
          featured={build.data.featured}
          index={i + 1}
          patch={build.data.patch}
          playstyle_tag={build.data.playstyle_tag}
          subclass={build.data.subclass}
        />
      ))}
    </div>

    <TwitchEmbed variant="landing" />

  </div>
</Base>

<style>
  .bi {
    max-width: 1120px;
    margin: 0 auto;
    padding: 64px 24px 96px;
  }

  /* ── Masthead ── */
  .bi__head {
    margin-bottom: 48px;
    text-align: center;
  }

  .bi__rail {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .bi__eyebrow,
  .bi__count {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.26em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .bi__count { color: var(--color-accent); }

  .bi__title {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 96px);
    font-style: italic;
    font-weight: 600;
    line-height: 0.95;
    background: linear-gradient(160deg, #ede8ff 0%, #a78bfa 60%, #6d28d9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 16px;
  }

  .bi__dek {
    font-family: var(--font-body);
    font-size: 22px;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Rule ── */
  .bi__rule {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .bi__rule-l {
    flex: 1;
    height: 1px;
    background: var(--color-border-2);
  }

  .bi__rule-lbl {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ── Class nav ── */
  .bi__cls-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }

  .bi__cls-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    text-decoration: none;
    transition: background 160ms, border-color 160ms;
  }

  .bi__cls-pill:hover {
    background: var(--color-surface-2);
    border-color: #3a3358;
  }

  .bi__cls-pill.on {
    border-color: rgba(139,92,246,0.5);
    background: rgba(139,92,246,0.08);
  }

  .bi__cls-name {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .bi__cls-ct {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-bg);
    background: var(--color-text-muted);
    padding: 1px 5px;
    min-width: 16px;
    text-align: center;
    line-height: 1.6;
  }

  .bi__cls-pill.on .bi__cls-ct { background: var(--color-accent); }

  /* ── Grid ── */
  .bi__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 12px;
  }

  @media (max-width: 640px) {
    .bi { padding: 40px 16px 72px; }
    .bi__cls-nav { gap: 6px; }
  }
</style>
