---
import Base from '../../../layouts/Base.astro';
---

<Base
  title="Subclass Builds"
  description="ESO subclass builds — mixing class skill lines to create custom archetypes."
>
  <div class="subclass-wrap">
    <header class="subclass-header">
      <p class="subclass-eyebrow">Builds</p>
      <h1 class="subclass-title">Subclass</h1>
      <p class="subclass-desc">
        Builds using mixed class skill lines — ESO's subclass system lets you combine
        abilities from different class lines to create your own archetype.
      </p>
    </header>

    <div class="subclass-empty">
      <p class="empty-message">No subclass builds published yet.</p>
    </div>
  </div>
</Base>

<style>
  .subclass-wrap {
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }

  .subclass-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .subclass-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }

  .subclass-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }

  .subclass-desc {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
    max-width: 52ch;
  }

  .subclass-empty {
    padding: 3rem 0;
    text-align: center;
  }

  .empty-message {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
</style>
