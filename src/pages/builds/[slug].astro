---
import { getCollection } from 'astro:content';
import Build from '../../layouts/Build.astro';

export async function getStaticPaths() {
  const builds = await getCollection('builds');
  return builds.map(build => ({
    params: { slug: build.id },
    props: { build },
  }));
}

const { build } = Astro.props;

const allSets        = await getCollection('sets');
const allSkills      = await getCollection('skills');
const allRaces       = await getCollection('races');
const allConsumables = await getCollection('consumables');

const setsMap        = Object.fromEntries(allSets.map(s => [s.id, s.data]));
const skillsMap      = Object.fromEntries(allSkills.map(s => [s.id, s.data]));
const racesMap       = Object.fromEntries(allRaces.map(r => [r.id, r.data]));
const consumablesMap = Object.fromEntries(allConsumables.map(c => [c.id, c.data]));

function assertIds(ids: string[], map: Record<string, unknown>, kind: string, buildId: string) {
  const missing = ids.filter(id => !(id in map));
  if (missing.length > 0) {
    throw new Error(
      `[build: ${buildId}] Missing ${kind} JSON for: ${missing.join(', ')}\n` +
      `Create the file(s) in src/content/${kind}s/ to fix this.`
    );
  }
}

assertIds(build.data.sets,          setsMap,   'set',   build.id);
assertIds(build.data.skills.bar1,   skillsMap, 'skill', build.id);
assertIds(build.data.skills.bar2,   skillsMap, 'skill', build.id);

const resolvedSets = build.data.sets.map(id => setsMap[id]!);
const resolvedRace = build.data.race ? (racesMap[build.data.race] ?? null) : null;

// Resolve consumable IDs → full data objects
const rawC = build.data.consumables;
const resolvedConsumables = rawC ? {
  food:   rawC.food   ? { data: consumablesMap[rawC.food.id]   ?? null, note: rawC.food.note,   alt: rawC.food.alt   } : undefined,
  potion: rawC.potion ? { data: consumablesMap[rawC.potion.id] ?? null, note: rawC.potion.note                       } : undefined,
  poison: rawC.poison ? { data: consumablesMap[rawC.poison.id] ?? null, note: rawC.poison.note                       } : undefined,
  mundus: rawC.mundus,
} : undefined;

function enrichSkill(id: string) {
  const skill = skillsMap[id]!;
  return {
    ...skill,
    morph_sibling_name: skill.morph_sibling ? (skillsMap[skill.morph_sibling]?.name ?? null) : null,
  };
}

const resolvedBar1 = build.data.skills.bar1.map(enrichSkill);
const resolvedBar2 = build.data.skills.bar2.map(enrichSkill);
---

<Build
  title={build.data.title}
  class={build.data.class}
  role={build.data.role}
  resource={build.data.resource}
  gamemode={build.data.gamemode}
  patch={build.data.patch}
  author={build.data.author}
  publishedDate={build.data.publishedDate}
  updatedAt={build.data.updatedAt}
  difficulty={build.data.difficulty}
  summary={build.data.summary}
  pullquote={build.data.pullquote}
  sets={resolvedSets}
  bar1={resolvedBar1}
  bar2={resolvedBar2}
  og_image={build.data.og_image}
  gear={build.data.gear}
  stats={build.data.stats}
  champion_points={build.data.champion_points}
  consumables={resolvedConsumables}
  playstyle={build.data.playstyle}
  race={resolvedRace}
/>
