---
import Base from '../layouts/Base.astro';
---

<Base title="Home" description="Kozy ESO PvP Builds — Optimized PvP builds, rotation guides, and ESO mechanics breakdowns.">
  <div class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="hero-eyebrow">Elder Scrolls Online</p>
      <h1 class="hero-title">PvP Builds &amp;<br/>Mechanic Guides</h1>
      <p class="hero-desc">
        Curated builds and breakdowns for players who want to understand
        why a setup works — not just copy it.
      </p>
      <div class="hero-links">
        <a href="/builds" class="btn-primary">Browse Builds</a>
        <a href="/articles" class="btn-secondary">Read Articles</a>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="section-inner">
      <p class="coming-soon-label">In progress</p>
      <h2 class="section-title">Content coming soon</h2>
      <p class="section-body">
        The first builds and articles are being written. Content covers PvP builds,
        gear optimization, skill morphs, and ESO mechanic deep-dives.
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-glow {
    position: absolute;
    top: -8rem;
    left: 50%;
    transform: translateX(-50%);
    width: 40rem;
    height: 30rem;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .hero-title {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 0 auto 2.5rem;
    line-height: 1.75;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dim));
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 8px;
    transition: opacity 0.15s, transform 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
    color: #fff;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 8px;
    transition: border-color 0.15s, color 0.15s, transform 0.15s;
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .section {
    padding: 4rem 1.5rem;
  }

  .section-inner {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
  }

  .coming-soon-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-size: 1.5rem;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .section-body {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
    font-size: 0.95rem;
  }
</style>
