---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BuildCard from '../components/BuildCard.astro';
import TwitchEmbed from '../components/TwitchEmbed.astro';
import { getFileDates } from '../lib/git-dates';

const allBuilds = await getCollection('builds');
const allGuides = await getCollection('guides');

const featuredBuilds = allBuilds
  .filter(b => b.data.featured)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 3);

const latestGuides = allGuides
  .map(g => {
    const { publishedDate } = getFileDates(g.filePath ?? `src/content/guides/${g.id}.md`);
    return { guide: g, publishedDate };
  })
  .sort((a, b) => (b.publishedDate ?? '').localeCompare(a.publishedDate ?? ''))
  .slice(0, 3);

const classes = ['Dragonknight', 'Sorcerer', 'Nightblade', 'Templar', 'Warden', 'Necromancer', 'Arcanist', 'Werewolf'];
const countByClass = Object.fromEntries(
  classes.map(c => [c, allBuilds.filter(b => b.data.class === c).length])
);

const CLASS_COLOR: Record<string, string> = {
  Dragonknight: '#e05c3a', Sorcerer: '#5b8fd6', Nightblade: '#9b59b6',
  Templar: '#d4a44a', Warden: '#5ebd6a', Necromancer: '#7ecac0',
  Arcanist: '#3cb371', Werewolf: '#c0792b',
};

const [mainBuild, ...rest] = featuredBuilds;
const stackedBuilds = rest.slice(0, 2);

const siteUrl = 'https://kozy-eso-pvp-builds.simbad14100.workers.dev';
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kozy ESO PvP Builds',
  url: siteUrl,
  description: 'Optimized PvP builds, rotation guides, and ESO mechanics breakdowns.',
};
---

<Base
  title="Home"
  description="Optimized builds, rotation guides, and mechanic breakdowns for Elder Scrolls Online PvP."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <!-- ── HERO : editorial 2-col, gauche-aligné ── -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__left">
        <p class="hero__eyebrow">
          <span>Elder Scrolls Online</span>
          <span class="hero__sep" aria-hidden="true">·</span>
          <span>PvP</span>
          <span class="hero__sep" aria-hidden="true">·</span>
          <span>Update 50</span>
        </p>
        <h1 class="hero__title">Builds that<br/>keep up with<br/>the meta.</h1>
        <div class="hero__accent" aria-hidden="true"></div>
      </div>
      <div class="hero__right">
        <p class="hero__dek">
          Curated builds and breakdowns for players who want to understand
          <em>why</em> a setup works — not just copy it.
        </p>
        <div class="hero__cta">
          <a href="/builds" class="hero__btn hero__btn--primary">Browse Builds</a>
          <a href="/guides" class="hero__btn hero__btn--secondary">Read Guides</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TWITCH ── -->
  <TwitchEmbed variant="landing" />

  <!-- ── 01 · FEATURED BUILDS ── -->
  {mainBuild && (
    <section class="hp-sec">
      <div class="hp-sec__inner">
        <div class="hp-sh">
          <span class="hp-sh__num">01</span>
          <h2 class="hp-sh__title">Featured Builds</h2>
          <div class="hp-sh__rule" aria-hidden="true"></div>
          <a href="/builds" class="hp-sh__link">All builds →</a>
        </div>

        <div class:list={['hp-feature', stackedBuilds.length === 0 && 'hp-feature--single']}>
          <!-- Carte principale large -->
          <a
            href={`/builds/${mainBuild.id}/`}
            class="hp-feat"
            style={`--cls: ${CLASS_COLOR[mainBuild.data.class] ?? 'var(--color-accent)'};`}
          >
            <div class="hp-feat__top">
              <span class="hp-feat__label">Featured</span>
              <span class="hp-feat__meta">
                {mainBuild.data.resource} {mainBuild.data.class}
                <span aria-hidden="true"> · </span>
                {mainBuild.data.gamemode[0]}
              </span>
            </div>
            <strong class="hp-feat__name">{mainBuild.data.title}</strong>
            <p class="hp-feat__sum">{mainBuild.data.summary}</p>
            <div class="hp-feat__foot">
              <span>{mainBuild.data.difficulty}</span>
              <span aria-hidden="true"> · </span>
              <span>{mainBuild.data.patch}</span>
            </div>
          </a>

          <!-- Cartes secondaires empilées -->
          {stackedBuilds.length > 0 && (
            <div class="hp-feat-stack">
              {stackedBuilds.map((build, i) => (
                <BuildCard
                  title={build.data.title}
                  slug={build.id}
                  class={build.data.class}
                  role={build.data.role}
                  resource={build.data.resource}
                  gamemode={build.data.gamemode}
                  patch={build.data.patch}
                  difficulty={build.data.difficulty}
                  summary={build.data.summary}
                  featured={build.data.featured}
                  index={i + 2}
                  playstyle_tag={build.data.playstyle_tag}
                  subclass={build.data.subclass}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ── 02 · BROWSE BY CLASS ── -->
  <section class="hp-sec hp-sec--dim">
    <div class="hp-sec__inner">
      <div class="hp-sh">
        <span class="hp-sh__num">02</span>
        <h2 class="hp-sh__title">Browse by Class</h2>
        <div class="hp-sh__rule" aria-hidden="true"></div>
      </div>
      <nav class="hp-cls" aria-label="Browse builds by class">
        {classes.map(c => (
          <a href={`/builds/class/${c.toLowerCase()}/`} class="hp-cls__item">
            <span class="hp-cls__name">{c}</span>
            <span class="hp-cls__ct">{countByClass[c]}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- ── 03 · LATEST GUIDES ── -->
  {latestGuides.length > 0 && (
    <section class="hp-sec">
      <div class="hp-sec__inner">
        <div class="hp-sh">
          <span class="hp-sh__num">03</span>
          <h2 class="hp-sh__title">Latest Guides</h2>
          <div class="hp-sh__rule" aria-hidden="true"></div>
          <a href="/guides" class="hp-sh__link">All guides →</a>
        </div>
        <ol class="hp-guides">
          {latestGuides.map(({ guide, publishedDate }, i) => (
            <li>
              <a href={`/guides/${guide.id}/`} class="hp-guide">
                <div class="hp-guide__meta">
                  <span class="hp-guide__idx">{String(i + 1).padStart(2, '0')}</span>
                  <span class="hp-guide__cat">{guide.data.category.toUpperCase()}</span>
                  {publishedDate && (
                    <time datetime={publishedDate} class="hp-guide__date">
                      {new Date(publishedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </time>
                  )}
                </div>
                <h3 class="hp-guide__title">{guide.data.title}</h3>
                <p class="hp-guide__sum">{guide.data.summary}</p>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}
</Base>

<style>
  /* ─────────────────────────────────────────────
     HERO — 2 colonnes, gauche-aligné, sans sigil
     ───────────────────────────────────────────── */
  .hero {
    padding: 88px 0 80px;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 72px;
    align-items: center;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 64px;
  }

  /* Eyebrow sobre — accent color, peu d'espacement */
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0 0 24px;
  }
  .hero__sep { color: var(--color-border-2); }

  /* Titre solid — pas de gradient (le tell AI le plus visible) */
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(54px, 7.5vw, 104px);
    font-style: italic;
    font-weight: 600;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0 0 28px;
  }

  /* Petite ligne accent — signature visuelle sobre */
  .hero__accent {
    width: 36px;
    height: 2px;
    background: var(--color-accent);
  }

  .hero__dek {
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 36px;
  }
  .hero__dek em { font-style: italic; color: var(--color-text); }

  .hero__cta { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero__btn {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 13px 26px;
    transition: background 150ms, color 150ms, transform 150ms;
    display: inline-block;
  }
  .hero__btn:hover { transform: translateY(-1px); }

  .hero__btn--primary { background: var(--color-accent); color: #fff; }
  .hero__btn--primary:hover { background: #7c3aed; }

  .hero__btn--secondary {
    background: transparent;
    border: 1px solid var(--color-border-2);
    color: var(--color-text-muted);
  }
  .hero__btn--secondary:hover {
    border-color: rgba(139,92,246,0.45);
    color: var(--color-text);
  }

  /* ─────────────────────────────────────────────
     SECTIONS
     ───────────────────────────────────────────── */
  .hp-sec {
    padding: 72px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .hp-sec--dim { background: var(--color-surface); }

  .hp-sec__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 64px;
  }

  /* Section header éditorial : [01]  Titre  ────  lien → */
  .hp-sh {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 36px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border-2);
  }

  .hp-sh__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  /* Titre section — Cormorant italic, solide, pas de gradient */
  .hp-sh__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
    flex-shrink: 0;
  }

  .hp-sh__rule {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .hp-sh__link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    text-decoration: none;
    flex-shrink: 0;
    transition: color 150ms;
  }
  .hp-sh__link:hover { color: var(--color-accent); }

  /* ─────────────────────────────────────────────
     FEATURED : large card + colonne empilée
     ───────────────────────────────────────────── */
  .hp-feature {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 12px;
    align-items: stretch;
  }
  .hp-feature--single { grid-template-columns: 1fr; }

  .hp-feat {
    --cls: var(--color-accent);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-top: 2px solid var(--cls);
    padding: 36px 40px;
    text-decoration: none;
    color: inherit;
    transition: background 200ms;
  }
  .hp-feat:hover { background: var(--color-surface-2); }

  .hp-feat__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
  }

  .hp-feat__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--cls);
    text-transform: uppercase;
  }

  .hp-feat__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  /* Titre build principal — solid, grand, pas de gradient */
  .hp-feat__name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(40px, 4.8vw, 62px);
    font-style: italic;
    font-weight: 600;
    line-height: 0.96;
    color: var(--color-text);
    margin-bottom: 20px;
    flex: 1;
  }

  .hp-feat__sum {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  .hp-feat__foot {
    display: flex;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-top: 28px;
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
  }

  .hp-feat-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ─────────────────────────────────────────────
     CLASSES — pills horizontaux
     ───────────────────────────────────────────── */
  .hp-cls {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hp-cls__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: var(--color-bg);
    border: 1px solid var(--color-border-2);
    text-decoration: none;
    transition: background 140ms, border-color 140ms;
  }
  .hp-cls__item:hover {
    background: var(--color-surface-2);
    border-color: #3a3358;
  }

  .hp-cls__name {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em; /* réduit vs l'original 0.12em */
    color: var(--color-text);
    text-transform: uppercase;
  }

  .hp-cls__ct {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-bg);
    background: var(--color-text-muted);
    padding: 1px 5px;
    min-width: 16px;
    text-align: center;
    line-height: 1.6;
  }

  /* ─────────────────────────────────────────────
     GUIDES — liste éditoriale
     ───────────────────────────────────────────── */
  .hp-guides {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hp-guides li { border-bottom: 1px solid var(--color-border); }
  .hp-guides li:first-child { border-top: 1px solid var(--color-border-2); }

  .hp-guide {
    display: block;
    padding: 26px 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 180ms;
  }
  .hp-guide:hover { padding-left: 10px; }

  .hp-guide__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .hp-guide__idx {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-border-2);
  }

  .hp-guide__cat {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .hp-guide__date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .hp-guide__title {
    font-family: var(--font-display);
    font-size: clamp(19px, 2.5vw, 26px);
    font-style: italic;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.15;
    margin: 0 0 8px;
  }

  .hp-guide__sum {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ─────────────────────────────────────────────
     RESPONSIVE
     ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero__inner,
    .hp-sec__inner { padding: 0 40px; }
    .hero__inner { gap: 48px; }
  }

  @media (max-width: 860px) {
    .hero__inner { grid-template-columns: 1fr; gap: 32px; }
    .hp-feature  { grid-template-columns: 1fr; }
    .hp-feat-stack { flex-direction: row; }
  }

  @media (max-width: 640px) {
    .hero { padding: 56px 0 48px; }
    .hero__inner,
    .hp-sec__inner { padding: 0 20px; }
    .hp-sec { padding: 48px 0; }
    .hp-feat { padding: 24px 20px; }
    .hp-feat-stack { flex-direction: column; }
    .hero__btn { padding: 12px 20px; font-size: 11px; }
  }
</style>
