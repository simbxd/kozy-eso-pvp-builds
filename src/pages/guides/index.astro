---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allGuides = await getCollection('guides');
const sorted = allGuides.sort((a, b) =>
  b.data.published.getTime() - a.data.published.getTime()
);
---

<Base title="Guides" description="ESO mechanic breakdowns, PvP theory, and deep-dives by Kozy.">
  <div class="page-wrap">
    <header class="page-header">
      <h1 class="page-title">Guides</h1>
      <p class="page-desc">Mechanic breakdowns, theory, and ESO deep-dives.</p>
    </header>

    <ol class="article-list">
      {sorted.map(guide => {
        const date = guide.data.published.toLocaleDateString('en-GB', {
          day: 'numeric', month: 'long', year: 'numeric',
        });
        return (
          <li class="article-item">
            <a href={`/guides/${guide.id}`} class="article-link">
              <div class="article-meta">
                <span class="article-category">{guide.data.category}</span>
                <time datetime={guide.data.published.toISOString()} class="article-date">
                  {date}
                </time>
              </div>
              <h2 class="article-title">{guide.data.title}</h2>
              <p class="article-summary">{guide.data.summary}</p>
              <div class="article-tags">
                {guide.data.tags.map(tag => <span class="tag">#{tag}</span>)}
              </div>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</Base>

<style>
  .page-wrap {
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .page-desc { color: var(--color-text-muted); margin: 0; }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-item {
    border-bottom: 1px solid var(--color-border);
  }

  .article-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.15s;
  }

  .article-link:hover { padding-left: 0.5rem; }

  .article-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .article-category {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .article-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }
</style>
