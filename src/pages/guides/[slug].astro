---
import { getCollection, render } from 'astro:content';
import Guide from '../../layouts/Guide.astro';
import { getFileDates } from '../../lib/git-dates';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { updatedAt } = getFileDates(guide.filePath ?? `src/content/guides/${guide.id}.md`);

const allGuides = await getCollection('guides');
const readNextGuides = allGuides
  .filter(g => g.id !== guide.id)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 2);
---

<Guide
  title={guide.data.title}
  category={guide.data.category}
  tags={guide.data.tags}
  published={guide.data.published}
  summary={guide.data.summary}
  og_image={guide.data.og_image}
  patch={guide.data.patch}
  readTime={guide.data.readTime}
  updatedAt={updatedAt}
  readNextGuides={readNextGuides}
>
  <Content />
</Guide>
