---
import Base from './Base.astro';

interface Props {
  title: string;
  category: string;
  tags: string[];
  published: Date;
  summary: string;
  og_image?: string;
}

const { title, category, tags, published, summary, og_image } = Astro.props;

const formattedDate = published.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base title={title} description={summary} ogImage={og_image}>
  <div class="article-wrap">
    <header class="article-header">
      <div class="article-meta">
        <span class="article-category">{category}</span>
        <time datetime={published.toISOString()} class="article-date">{formattedDate}</time>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-summary">{summary}</p>
      <div class="article-tags">
        {tags.map(tag => <span class="tag">#{tag}</span>)}
      </div>
    </header>

    <div class="article-body prose">
      <slot />
    </div>
  </div>
</Base>

<style>
  .article-wrap {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .article-category {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .article-summary {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0 0 1.25rem;
    line-height: 1.7;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.45rem;
    border-radius: 2px;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.2rem;
    color: var(--color-text);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-mono);
    background-color: var(--color-surface);
    padding: 0.15em 0.35em;
    border-radius: 2px;
  }

  .prose :global(pre) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.2rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .prose :global(th) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  .prose :global(td) {
    padding: 0.45rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent-dim);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(hr) {
    border-color: var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(a) {
    color: var(--color-accent);
  }
</style>
