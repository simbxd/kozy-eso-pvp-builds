---
import Base from './Base.astro';

interface GuideEntry {
  id: string;
  publishedDate: string | null;
  data: {
    title: string;
    category: string;
    summary: string;
    readTime?: string;
  };
}

interface Props {
  title: string;
  category: string;
  tags: string[];
  publishedDate: string | null;
  summary: string;
  og_image?: string;
  patch?: string;
  readTime?: string;
  updatedAt?: string | null;
  readNextGuides?: GuideEntry[];
}

const {
  title, category, tags, publishedDate, summary, og_image,
  patch, readTime, updatedAt, readNextGuides = [],
} = Astro.props;

const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

const formattedUpdated = updatedAt && updatedAt !== publishedDate
  ? new Date(updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : null;

const siteUrl    = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://kozy-eso.com';
const canonical  = new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbs = og_image
  ? (og_image.startsWith('http') ? og_image : `${siteUrl}${og_image}`)
  : `${siteUrl}/assets/og/og-default.png`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  image: ogImageAbs,
  datePublished: publishedDate,
  dateModified: updatedAt ?? publishedDate,
  author: { '@type': 'Person', name: 'Kozy' },
  publisher: {
    '@type': 'Organization',
    name: 'Kozy ESO PvP Builds',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  mainEntityOfPage: canonical,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: siteUrl + '/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: siteUrl + '/guides/' },
    { '@type': 'ListItem', position: 3, name: title,    item: canonical },
  ],
};
---

<Base title={title} description={summary} ogImage={og_image} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <article class="art">

    <header class="art__head">
      <div class="art__rail">
        {patch     && <span class="art__chip">{patch}</span>}
        {readTime  && <span class="art__chip">{readTime}</span>}
        {formattedUpdated && <span class="art__chip">UPD {formattedUpdated}</span>}
        <span class="art__chip art__chip--cat">{category.toUpperCase()}</span>
      </div>

      <h1 class="art__title">{title}</h1>
      <p  class="art__dek">{summary}</p>

      <div class="art__byline">
        {formattedDate && publishedDate && (
          <time datetime={publishedDate} class="art__date">{formattedDate}</time>
        )}
        {tags.length > 0 && (
          <div class="art__tags">
            {tags.map(tag => <span class="art__tag">#{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <div class="art__rule" aria-hidden="true">
      <div class="art__rule-line"></div>
    </div>

    <div class="art__body">
      <slot />
    </div>

    <footer class="art__foot">
      <div class="art__end">
        <div class="art__end-line"></div>
        <span class="art__end-label">── END ──</span>
        <div class="art__end-line"></div>
      </div>

      {readNextGuides.length > 0 && (
        <div class="art__rn">
          <div class="art__rn-head">READ NEXT</div>
          <div class="art__rn-list">
            {readNextGuides.map(g => (
              <a href={`/guides/${g.id}`} class="art__rn-item">
                <div class="art__rn-meta">
                  <span class="art__rn-cat">{g.data.category.toUpperCase()}</span>
                  {g.publishedDate && (
                    <span class="art__rn-date">
                      {new Date(g.publishedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                  )}
                  {g.data.readTime && <span class="art__rn-rt">{g.data.readTime}</span>}
                </div>
                <div class="art__rn-title">{g.data.title}</div>
                <div class="art__rn-sum">{g.data.summary}</div>
              </a>
            ))}
          </div>
        </div>
      )}
    </footer>

  </article>
</Base>

<style>
  .art {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 96px;
  }

  /* ── Masthead ── */
  .art__head {
    margin-bottom: 40px;
  }

  .art__rail {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 28px;
  }

  .art__chip {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.22em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .art__chip--cat {
    color: var(--color-accent);
    padding: 3px 8px;
    border: 1px solid rgba(139,92,246,0.3);
    background: rgba(139,92,246,0.06);
  }

  .art__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 64px);
    font-style: italic;
    font-weight: 600;
    line-height: 1.05;
    color: var(--color-text);
    background: linear-gradient(160deg, #ede8ff 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 20px;
  }

  .art__dek {
    font-family: var(--font-body);
    font-size: 20px;
    font-style: italic;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0 0 24px;
  }

  .art__byline {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .art__date {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .art__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .art__tag {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 2px 7px;
  }

  /* ── Rule ── */
  .art__rule {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 44px;
  }

  .art__rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent) 0%, transparent 100%);
    opacity: 0.35;
  }

  /* ── Body prose ── */
  .art__body :global(p) {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 1.35em;
  }

  .art__body :global(p:first-child::first-letter) {
    font-family: var(--font-display);
    font-size: 4.2em;
    font-weight: 600;
    float: left;
    line-height: 0.78;
    margin: 0.06em 0.1em 0 0;
    color: var(--color-accent);
    text-shadow: 0 0 32px var(--color-accent-glow);
  }

  .art__body :global(h2) {
    font-family: var(--font-display);
    font-size: 36px;
    font-style: italic;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.1;
    margin: 3rem 0 1rem;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border-2);
  }

  .art__body :global(h3) {
    font-family: var(--font-display);
    font-size: 24px;
    font-style: italic;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
    margin: 2.2rem 0 0.8rem;
  }

  .art__body :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .art__body :global(em) {
    font-style: italic;
    color: #c4b5fd;
  }

  .art__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-mono);
    background: var(--color-surface-2);
    padding: 2px 6px;
    border: 1px solid var(--color-border-2);
  }

  .art__body :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-left: 2px solid var(--color-accent);
    padding: 20px 22px;
    overflow-x: auto;
    margin: 1.8em 0;
  }

  .art__body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.65;
  }

  .art__body :global(ul),
  .art__body :global(ol) {
    padding-left: 1.5em;
    margin: 0 0 1.35em;
  }

  .art__body :global(li) {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.65;
    color: var(--color-text);
    margin-bottom: 0.4em;
  }

  .art__body :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    margin: 2em 0;
    padding: 20px 28px;
    background: var(--color-surface);
  }

  .art__body :global(blockquote p) {
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
  }

  .art__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
  }

  .art__body :global(th) {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-border-2);
  }

  .art__body :global(td) {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--color-text);
    padding: 9px 12px;
    border-bottom: 1px solid var(--color-border);
  }

  .art__body :global(tr:last-child td) {
    border-bottom: none;
  }

  .art__body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border-2);
    margin: 2.5em 0;
  }

  .art__body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(139,92,246,0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 180ms;
  }

  .art__body :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  /* ── Footer / End rule ── */
  .art__foot {
    margin-top: 72px;
  }

  .art__end {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 56px;
  }

  .art__end-line {
    flex: 1;
    height: 1px;
    background: var(--color-border-2);
  }

  .art__end-label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.28em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ── Read Next ── */
  .art__rn-head {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.3em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .art__rn-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .art__rn-item {
    display: block;
    padding: 20px 22px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-2);
    border-top: 1px solid var(--color-border-2);
    text-decoration: none;
    transition: background 200ms, border-color 200ms, transform 200ms;
    position: relative;
  }

  .art__rn-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 240ms cubic-bezier(.2,.8,.2,1);
  }

  .art__rn-item:hover {
    background: var(--color-surface-2);
    border-color: #3a3358;
    transform: translateY(-2px);
  }

  .art__rn-item:hover::before {
    transform: scaleY(1);
  }

  .art__rn-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .art__rn-cat {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--color-accent);
  }

  .art__rn-date,
  .art__rn-rt {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .art__rn-title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 500;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .art__rn-sum {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .art {
      padding: 40px 16px 72px;
    }

    .art__body :global(p:first-child::first-letter) {
      font-size: 3.6em;
    }

    .art__rn-list {
      grid-template-columns: 1fr;
    }
  }
</style>
