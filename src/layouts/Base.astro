---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Optimized PvP builds, rotation guides, and ESO mechanics breakdowns for Elder Scrolls Online.',
  ogImage = '/assets/og/og-default.png',
  canonicalUrl,
  ogType = 'website',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://kozy-eso.com';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
// Bump when the default OG image content changes — forces Discord/Twitter to drop their cached copy
const OG_VERSION = '2';
const ogImageBase = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const ogImageAbsolute = ogImage === '/assets/og/og-default.png' ? `${ogImageBase}?v=${OG_VERSION}` : ogImageBase;
const fullTitle = title === 'Home' ? 'kozy-eso.com — Builds, Guides & Mechanics for ESO PvP' : `${title} — Kozy ESO PvP Builds`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts — preconnect + stylesheet in HTML so browser discovers fonts without waiting for CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" />

    <!-- Favicon — ?v bumped with OG_VERSION to bust aggressive browser favicon cache -->
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${OG_VERSION}`} />
    <link rel="icon" href={`/favicon.ico?v=${OG_VERSION}`} />
    <meta name="theme-color" content="#8b5cf6" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Kozy ESO PvP Builds" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="kz-page">
      <div class="kz-page__vignette" aria-hidden="true"></div>
      <Header />
      <div class="kz-page__inner">
        <main id="main-content">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-radius: 0 0 4px 4px;
    text-decoration: none;
    z-index: 100;
    transition: top 0.1s;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
