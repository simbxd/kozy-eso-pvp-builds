        <span class="kz-rule__label">Champion Points</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="cp__grid">
        {[
          { label: 'Warfare', stars: champion_points.warfare },
          { label: 'Fitness', stars: champion_points.fitness },
        ].filter(c => c.stars?.length).map(({ label, stars }) => (
          <div class="supply-card supply-card--cp">
            <div class="supply-card__kicker">{label}</div>
            <ul class="cp-list">
              {[...stars].sort((a, b) => a.priority - b.priority).map(s => {
                const effect = cpEffectMap.get(s.star);
                return (
                  <li>
                    <span class="cp-list__rank">{s.priority}</span>
                    {effect ? (
                      <span class="cp-list__star cp-list__star--tip" tabindex="0">
                        {s.star}
                        <span class="cp-list__tip" role="tooltip">{effect}</span>
                      </span>
                    ) : (
                      <span class="cp-list__star">{s.star}</span>
                    )}
                    <span class="cp-list__dots" aria-hidden="true"></span>
                    <span class="cp-list__pts">{s.points}</span>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

