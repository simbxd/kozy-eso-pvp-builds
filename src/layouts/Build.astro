  <!-- MOBILE FAB -->
  <button class="toc-fab" id="toc-fab" aria-label="Open sections menu" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <line x1="3" y1="5"  x2="17" y2="5"  stroke="white" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="3" y1="10" x2="17" y2="10" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="3" y1="15" x2="13" y2="15" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- MOBILE DRAWER -->
  <div class="toc-drawer" id="toc-drawer" aria-hidden="true">
    <div class="toc-drawer__inner">
      <div class="toc-drawer__label">Sections</div>
      <nav>
        <a href="#overview"        class="toc-drawer__link">Overview</a>
        {race && <a href="#race" class="toc-drawer__link">Race</a>}
        <a href="#skill-bars"      class="toc-drawer__link">Skill Bars</a>
        {hasPlaystyle && <a href="#playstyle" class="toc-drawer__link">Playstyle</a>}
        <a href="#set-choices"      class="toc-drawer__link">Set Choices</a>
        <a href="#gear-sheet"      class="toc-drawer__link">Gear Sheet</a>
        <a href="#consumables"     class="toc-drawer__link">Consumables</a>
        <a href="#champion-points" class="toc-drawer__link">Champion Points</a>
      </nav>
    </div>
  </div>
  <div class="toc-overlay" id="toc-overlay"></div>

</Base>

<script>
  // ── TOC: IntersectionObserver ─────────────────────────
  const sections  = document.querySelectorAll('section[id]');
  const tocLinks  = document.querySelectorAll('.toc__link');

  if (sections.length && tocLinks.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('toc__link--active'));
          document.querySelector(`.toc__link[href="#${entry.target.id}"]`)
            ?.classList.add('toc__link--active');
        }
      });
    }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });

    sections.forEach(s => observer.observe(s));
  }

  // ── Mobile FAB + Drawer ───────────────────────────────
  const fab     = document.getElementById('toc-fab');
  const drawer  = document.getElementById('toc-drawer');
  const overlay = document.getElementById('toc-overlay');

  function openDrawer() {
    drawer?.classList.add('toc-drawer--open');
    overlay?.classList.add('toc-overlay--show');
    fab?.setAttribute('aria-expanded', 'true');
    drawer?.setAttribute('aria-hidden', 'false');
  }

  function closeDrawer() {
    drawer?.classList.remove('toc-drawer--open');
    overlay?.classList.remove('toc-overlay--show');
    fab?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
  }

  fab?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);

  document.querySelectorAll('.toc-drawer__link').forEach(link => {
    link.addEventListener('click', () => {
      closeDrawer();
      const id = (link as HTMLAnchorElement).hash.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
    });
  });

  // Smooth scroll with reduced-motion respect for sidebar links
  document.querySelectorAll('.toc__link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const id = (link as HTMLAnchorElement).hash.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      history.pushState(null, '', `#${id}`);
    });
  });
</script>

