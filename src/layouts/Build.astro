<script>
  // ── TOC: IntersectionObserver ─────────────────────────
  const sections  = document.querySelectorAll('section[id]');
  const tocLinks  = document.querySelectorAll('.toc__link');

  if (sections.length && tocLinks.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('toc__link--active'));
          document.querySelector(`.toc__link[href="#${entry.target.id}"]`)
            ?.classList.add('toc__link--active');
        }
      });
    }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });

    sections.forEach(s => observer.observe(s));
  }

  // ── Mobile FAB + Drawer ───────────────────────────────
  const fab     = document.getElementById('toc-fab');
  const drawer  = document.getElementById('toc-drawer');
  const overlay = document.getElementById('toc-overlay');

  function openDrawer() {
    drawer?.classList.add('toc-drawer--open');
    overlay?.classList.add('toc-overlay--show');
    fab?.setAttribute('aria-expanded', 'true');
    drawer?.setAttribute('aria-hidden', 'false');
  }

  function closeDrawer() {
    drawer?.classList.remove('toc-drawer--open');
    overlay?.classList.remove('toc-overlay--show');
    fab?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('aria-hidden', 'true');
  }

  fab?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);

  document.querySelectorAll('.toc-drawer__link').forEach(link => {
    link.addEventListener('click', () => {
      closeDrawer();
      const id = (link as HTMLAnchorElement).hash.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
    });
  });

  // Smooth scroll with reduced-motion respect for sidebar links
  document.querySelectorAll('.toc__link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const id = (link as HTMLAnchorElement).hash.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      history.pushState(null, '', `#${id}`);
    });
  });
</script>

<script>
  // ── Gear sheet — ESO-Hub set tooltips, lazy fetch on hover/focus ──
  import { fetchSetTip, setTipBonuses } from "@/lib/esohub-api";

  document.querySelectorAll<HTMLElement>(".gr__set-wrap[data-set-id]").forEach((wrap) => {
    const id  = wrap.dataset.setId;
    const tip = wrap.querySelector(".gr__set-tip");
    if (!id || !tip) return;
    const body     = tip.querySelector<HTMLElement>("[data-eso-body]");
    const fallback = tip.querySelector<HTMLElement>("[data-fallback]");
    if (!body) return;

    let loaded = false;
    const load = async () => {
      if (loaded) return;
      loaded = true;
      const data = await fetchSetTip(id);
      if (!data) return; // keep local fallback on failure
      let html = "";
      for (const { count, html: bonusHtml } of setTipBonuses(data)) {
        html += `<span class="gr__set-tip-row"><span class="gr__set-tip-n">${count}pc</span>`
              + `<span class="gr__set-tip-txt">${bonusHtml}</span></span>`;
      }
      html += `<span class="gr__set-tip-credit">Tooltips by ESO-Hub</span>`;
      body.innerHTML = html;
      body.hidden = false;
      if (fallback) fallback.hidden = true;
    };

    wrap.addEventListener("mouseenter", load);
    wrap.addEventListener("focusin", load);
  });
</script>

