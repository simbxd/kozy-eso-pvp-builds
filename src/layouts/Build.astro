---
import type { ImageMetadata } from 'astro';
import Base from './Base.astro';
import BuildHero from '../components/BuildHero.astro';
import SetCard from '../components/SetCard.astro';
import Playstyle from '../components/Playstyle.astro';
import cpStarsIndex from '../data/eso/cp-stars-index.json';

interface Bonus {
  count: number;
  stat: string;
  value: number | string;
}

interface SetData {
  id: string;
  name: string;
  type: string;
  acquisition: string;
  location: string;
  dlc: string;
  pieces: number;
  bonuses: Bonus[];
  uesp_url: string;
  esohub_url: string;
}

interface SkillData {
  id: string;
  name: string;
  base_skill?: string | null;
  morph_of?: string | null;
  morph_sibling?: string | null;
  morph_sibling_name?: string | null;
  morph_rationale?: string | null;
  class: string;
  skill_line: string;
  type: string;
  resource?: string;
  icon?: string;
}

interface RacePassive { name: string; description: string; }
interface RaceData {
  id: string;
  name: string;
  alliance: string;
  passives: RacePassive[];
  uesp_url: string;
}

interface CPStar { star: string; points: number; priority: number; }

interface TraitData  { id: string; name: string; category: string; effect?: string; value_range: string; }
interface EnchantData { id: string; name: string; category: string; rune_prefix: string; effect: string; }

interface GearItem {
  slot: string;
  type: string;
  item?: string;
  setId: string;
  setName?: string;
  tier: string;
  trait: string;
  enchant: string;
  traitData?: TraitData | null;
  enchantData?: EnchantData | null;
  barLabel?: string;
  weapon_type?: string;
}

// Consumable data shape (resolved from collection)
type ConsumableEffect =
  | { stat: string; value: number | string }
  | { description: string };

interface ConsumableData {
  id: string;
  name: string;
  type: string;
  patch_verified: string;
  uesp_url: string;
  description?: string;
  effects: ConsumableEffect[];
  duration_seconds?: number;
  reagents?: string[];
  crafted: boolean;
}

interface ResolvedConsumable {
  data: ConsumableData | null;
  note?: string;
  alt?: string;
}

interface Props {
  slug: string;
  title: string;
  class: string;
  featured: boolean;
  role: string;
  resource: string;
  gamemode: string[];
  patch: string;
  author: string;
  publishedDate?: string;
  updatedAt?: string;
  difficulty: string;
  summary: string;
  sets: SetData[];
  bar1: SkillData[];
  bar2: SkillData[];
  og_image?: string;
  gear?: {
    armor:   GearItem[];
    jewelry: GearItem[];
    weapons: GearItem[];
  };
  stats?: {
    health:  { target: number; note: string };
    magicka: { target: number; note: string };
    stamina: { target: number; note: string };
  };
  champion_points?: {
    warfare: CPStar[];
    fitness: CPStar[];
  };
  consumables?: {
    food?:   ResolvedConsumable;
    potion?: ResolvedConsumable;
    poison?: ResolvedConsumable;
    mundus?: { stone: string; effect?: string; note?: string; alt?: { stone: string; effect?: string; note?: string } };
  };
  playstyle?: {
    buffs?: { skill: string; stat: string; note: string; uptime: 'full' | 'high' | 'situational' }[];
    combo?: { skill: string; skill_alt?: string; role: string }[];
    rules?: { title: string; body: string }[];
  };
  race?: RaceData | null;
  video_id?: string;
  character?: ImageMetadata;
}

const {
  slug, title, class: esClass, featured, role, resource, gamemode,
  patch, author, publishedDate, updatedAt, difficulty, summary,
  sets, bar1, bar2, og_image, gear, stats, champion_points, consumables, playstyle, race, video_id,
  character,
} = Astro.props;

const cpEffectMap = new Map<string, string>();
for (const star of [...cpStarsIndex.warfare, ...cpStarsIndex.fitness]) {
  cpEffectMap.set(star.name, star.effect);
}

const gamemodeLabel = gamemode.length === 1 ? gamemode[0] : 'PvP';
const subtitle = `${resource} ${esClass} ${gamemodeLabel} Build`;
const h1Text   = `${title} — ${subtitle}`;

const siteUrl        = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://kozy-eso.com';
const canonical      = new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbs     = og_image
  ? (og_image.startsWith('http') ? og_image : `${siteUrl}${og_image}`)
  : `${siteUrl}/assets/og/og-default.png`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1Text,
  description: summary,
  image: ogImageAbs,
  datePublished: publishedDate ?? updatedAt ?? null,
  dateModified: updatedAt ?? publishedDate ?? null,
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'Kozy ESO PvP Builds',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  mainEntityOfPage: canonical,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: siteUrl + '/' },
    { '@type': 'ListItem', position: 2, name: 'Builds', item: siteUrl + '/builds/' },
    { '@type': 'ListItem', position: 3, name: title,    item: canonical },
  ],
};

const hasPlaystyle = !!(
  playstyle && (
    playstyle.buffs?.length ||
    playstyle.combo?.length ||
    playstyle.rules?.length
  )
);

// Compute active pieces per set from gear data
const activePiecesMap = new Map<string, number>();
if (gear) {
  for (const item of [...gear.armor, ...gear.jewelry, ...gear.weapons]) {
    activePiecesMap.set(item.setId, (activePiecesMap.get(item.setId) ?? 0) + 1);
  }
}

// Set name lookup for gear sheet
const setNameById = Object.fromEntries(sets.map(s => [s.id, s.name]));
function setLabel(setId: string): string {
  return setNameById[setId] ?? setId;
}

// Set bonus lookup — local fallback for the gear sheet ESO-Hub tooltip
const setBonusById = new Map<string, Bonus[]>();
for (const s of sets) setBonusById.set(s.id, s.bonuses);

// ── BuildHero derived props ──────────────────────────────────────────────────
// Armor weight split for the rail caption — fixed heavy→light order, deduped.
const armorTypes = new Set((gear?.armor ?? []).map(p => p.type));
const armorSplit = ['heavy', 'medium', 'light']
  .filter(t => armorTypes.has(t))
  .map(t => t.charAt(0).toUpperCase() + t.slice(1))
  .join(' · ');

// Weapon types, grouped per bar so a Shield reads as "{weapon} & Shield".
const weaponsByBar = new Map<string, string[]>();
for (const w of gear?.weapons ?? []) {
  if (!w.weapon_type) continue;
  const key = w.barLabel ?? '';
  if (!weaponsByBar.has(key)) weaponsByBar.set(key, []);
  weaponsByBar.get(key)!.push(w.weapon_type);
}
const barWeaponLabels: string[] = [];
for (const types of weaponsByBar.values()) {
  if (types.includes('Shield')) {
    const other = types.find(t => t !== 'Shield');
    barWeaponLabels.push(other ? `${other} & Shield` : 'Shield');
  } else {
    barWeaponLabels.push([...new Set(types)].join(' / '));
  }
}
const weaponTypes = [...new Set(barWeaponLabels)].filter(Boolean).join(' / ');

const raceLabel = race?.name;
---

<Base title={`${title} — ${resource} ${esClass} PvP Build | ESO ${patch}`} description={summary} ogImage={og_image} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <!-- HERO — overview + identity + skill bars + character rail -->
  <BuildHero
    slug={slug}
    title={title}
    className={esClass}
    role={role}
    resource={resource}
    gamemode={gamemode}
    patch={patch}
    difficulty={difficulty}
    author={author}
    race={raceLabel}
    featured={featured}
    summary={summary}
    publishedDate={publishedDate}
    updatedAt={updatedAt}
    stats={stats}
    mundus={consumables?.mundus}
    character={character}
    bar1={bar1}
    bar2={bar2}
    armorSplit={armorSplit}
    weaponTypes={weaponTypes}
  />

  <!-- TWO-COLUMN LAYOUT -->
  <div class="build-layout">
  <div class="build-content">

  {video_id && (
    <section id="video-gameplay">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Video Gameplay</span>
        <span class="kz-rule__line"></span>
      </div>
      <div class="video-embed">
        <iframe
          src={`https://www.youtube.com/embed/${video_id}?rel=0&modestbranding=1`}
          title="Video Gameplay"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </section>
  )}

  <!-- PLAYSTYLE -->
  {hasPlaystyle && (
    <section id="playstyle">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Playstyle</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="prose">
        <Playstyle buffs={playstyle!.buffs} combo={playstyle!.combo} rules={playstyle!.rules} />
      </div>{/* /.prose */}
    </section>
  )}

  <!-- GEAR LOGIC -->
  <section id="set-choices">
  <div class="kz-rule" role="separator">
    <span class="kz-rule__line"></span>
    <span class="kz-rule__label">Set Choices</span>
    <span class="kz-rule__line"></span>
  </div>

  <div class="sets__grid">
    {sets.map((set, i) => (
      <SetCard
        id={set.id}
        index={i + 1}
        name={set.name}
        type={set.type}
        acquisition={set.acquisition}
        location={set.location}
        dlc={set.dlc}
        pieces={set.pieces}
        bonuses={set.bonuses}
        activePieces={activePiecesMap.get(set.id) ?? set.pieces}
        uesp_url={set.uesp_url}
        esohub_url={set.esohub_url}
      />
    ))}
  </div>

  </section>

  <!-- GEAR SHEET -->
  {gear && (
    <section id="gear-sheet">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Gear Sheet · Slot Assignments</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="gear__legend" aria-label="Armor weight color legend">
        <span class="gear__legend-item gear__legend-item--heavy">Heavy</span>
        <span class="gear__legend-item gear__legend-item--medium">Medium</span>
        <span class="gear__legend-item gear__legend-item--light">Light</span>
      </div>

      <div class="gear__cols">
        <!-- Armor -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Armor</span>
            <span class="gear__hd-count">{gear.armor.length} pieces</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.armor.map(row => (
                <tr class={`gr gr--${row.type}`}>
                  <td class="gr__slot"><span class="gr__pin" aria-hidden="true"></span>{row.slot}</td>
                  <td class="gr__item">
                    <span class="gr__set-wrap" data-set-id={row.setId} tabindex="0">
                      <span class="gr__name">{row.setName ?? row.setId}</span>
                      <span class="gr__set-tip" role="tooltip">
                        <span class="gr__set-tip-name">{row.setName ?? row.setId}</span>
                        <span class="gr__set-tip-eso eso-tip-body" data-eso-body hidden></span>
                        <span class="gr__set-tip-fb" data-fallback>
                          {(setBonusById.get(row.setId) ?? []).map(b => (
                            <span class="gr__set-tip-row">
                              <span class="gr__set-tip-n">{b.count}pc</span>
                              <span class="gr__set-tip-txt">{b.stat} {b.value}</span>
                            </span>
                          ))}
                        </span>
                      </span>
                    </span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Jewelry -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Jewelry</span>
            <span class="gear__hd-count">{gear.jewelry.length} pieces</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.jewelry.map(row => (
                <tr class={`gr gr--${row.type}`}>
                  <td class="gr__slot"><span class="gr__pin" aria-hidden="true"></span>{row.slot}</td>
                  <td class="gr__item">
                    <span class="gr__set-wrap" data-set-id={row.setId} tabindex="0">
                      <span class="gr__name">{row.setName ?? row.setId}</span>
                      <span class="gr__set-tip" role="tooltip">
                        <span class="gr__set-tip-name">{row.setName ?? row.setId}</span>
                        <span class="gr__set-tip-eso eso-tip-body" data-eso-body hidden></span>
                        <span class="gr__set-tip-fb" data-fallback>
                          {(setBonusById.get(row.setId) ?? []).map(b => (
                            <span class="gr__set-tip-row">
                              <span class="gr__set-tip-n">{b.count}pc</span>
                              <span class="gr__set-tip-txt">{b.stat} {b.value}</span>
                            </span>
                          ))}
                        </span>
                      </span>
                    </span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Weapons -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Weapons</span>
            <span class="gear__hd-count">2 bars · {gear.weapons.length} weapons</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.weapons.map(row => (
                <tr class="gr gr--weapon">
                  <td class="gr__slot">
                    <span class="gr__pin" aria-hidden="true"></span>
                    {row.slot}
                    <span class="gr__bar">{row.barLabel}</span>
                    {row.weapon_type && <span class="gr__wtype">{row.weapon_type}</span>}
                  </td>
                  <td class="gr__item">
                    <span class="gr__set-wrap" data-set-id={row.setId} tabindex="0">
                      <span class="gr__name">{row.setName ?? row.setId}</span>
                      <span class="gr__set-tip" role="tooltip">
                        <span class="gr__set-tip-name">{row.setName ?? row.setId}</span>
                        <span class="gr__set-tip-eso eso-tip-body" data-eso-body hidden></span>
                        <span class="gr__set-tip-fb" data-fallback>
                          {(setBonusById.get(row.setId) ?? []).map(b => (
                            <span class="gr__set-tip-row">
                              <span class="gr__set-tip-n">{b.count}pc</span>
                              <span class="gr__set-tip-txt">{b.stat} {b.value}</span>
                            </span>
                          ))}
                        </span>
                      </span>
                    </span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- CONSUMABLES -->
  {consumables && (
    <section id="consumables">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Consumables</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="supplies__grid">
        {/* ── Food ── */}
        {consumables.food?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Food</div>
            <h4 class="supply-card__name">{consumables.food.data.name}</h4>
            {consumables.food.data.description && (
              <p class="supply-card__body">{consumables.food.data.description}</p>
            )}
            {/* Stat effects (food/drink: { stat, value } objects) */}
            <ul class="supply-card__effects">
              {consumables.food.data.effects.map(fx => (
                'stat' in fx
                  ? <li><span class="supply-card__fx-stat">{fx.stat}</span><span class="supply-card__fx-val">{fx.value.toLocaleString()}</span></li>
                  : <li class="supply-card__fx-desc">{fx.description}</li>
              ))}
            </ul>
            {consumables.food.data.duration_seconds && (
              <p class="supply-card__meta">
                Duration · {consumables.food.data.duration_seconds >= 3600
                  ? `${consumables.food.data.duration_seconds / 3600}h`
                  : `${Math.round(consumables.food.data.duration_seconds / 60)}m`}
              </p>
            )}
            {consumables.food.note && <p class="supply-card__note">{consumables.food.note}</p>}
            {consumables.food.alt && <p class="supply-card__alt">Alt · {consumables.food.alt}</p>}
          </div>
        )}

        {/* ── Potion ── */}
        {consumables.potion?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Potion</div>
            <h4 class="supply-card__name">{consumables.potion.data.name}</h4>
            {consumables.potion.data.effects.map(fx => (
              'description' in fx
                ? <p class="supply-card__body">{fx.description}</p>
                : <p class="supply-card__body">{fx.stat} · {fx.value}</p>
            ))}
            {consumables.potion.data.reagents && consumables.potion.data.reagents.length > 0 && (
              <ul class="supply-card__ingredients">
                {consumables.potion.data.reagents.map(r => <li>{r}</li>)}
              </ul>
            )}
            {consumables.potion.note && <p class="supply-card__note">{consumables.potion.note}</p>}
          </div>
        )}

        {/* ── Poison ── */}
        {consumables.poison?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Poison</div>
            <h4 class="supply-card__name">{consumables.poison.data.name}</h4>
            {consumables.poison.data.effects.map(fx => (
              'description' in fx
                ? <p class="supply-card__body">{fx.description}</p>
                : <p class="supply-card__body">{fx.stat} · {fx.value}</p>
            ))}
            {consumables.poison.data.reagents && consumables.poison.data.reagents.length > 0 && (
              <ul class="supply-card__ingredients">
                {consumables.poison.data.reagents.map(r => <li>{r}</li>)}
              </ul>
            )}
            {consumables.poison.note && <p class="supply-card__note">{consumables.poison.note}</p>}
          </div>
        )}

        {/* ── Mundus (text-based, not yet a collection) ── */}
        {consumables.mundus && (
          <div class="supply-card supply-card--mundus">
            <div class="supply-card__kicker">Mundus Stone</div>
            <h4 class="supply-card__name">{consumables.mundus.stone}</h4>
            {consumables.mundus.effect && <p class="supply-card__body">{consumables.mundus.effect}</p>}
            {consumables.mundus.note && <p class="supply-card__note">{consumables.mundus.note}</p>}
            {consumables.mundus.alt && (
              <div class="supply-card__alt-block">
                <span class="supply-card__alt-label">Alt</span>
                <span class="supply-card__alt-name">{consumables.mundus.alt.stone}</span>
                {consumables.mundus.alt.effect && <span class="supply-card__alt-effect">{consumables.mundus.alt.effect}</span>}
                {consumables.mundus.alt.note && <span class="supply-card__alt-note">{consumables.mundus.alt.note}</span>}
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- CHAMPION POINTS -->
  {champion_points && (
    <section id="champion-points">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Champion Points</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="cp__grid">
        {[
          { label: 'Warfare', stars: champion_points.warfare },
          { label: 'Fitness', stars: champion_points.fitness },
        ].filter(c => c.stars?.length).map(({ label, stars }) => (
          <div class="supply-card supply-card--cp">
            <div class="supply-card__kicker">{label}</div>
            <ul class="cp-list">
