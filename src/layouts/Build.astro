---
import Base from './Base.astro';
import SetCard from '../components/SetCard.astro';
import SkillBar from '../components/SkillBar.astro';
import Playstyle from '../components/Playstyle.astro';
import cpStarsIndex from '../data/eso/cp-stars-index.json';

interface Bonus {
  count: number;
  stat: string;
  value: number | string;
}

interface SetData {
  id: string;
  name: string;
  type: string;
  acquisition: string;
  location: string;
  dlc: string;
  pieces: number;
  bonuses: Bonus[];
  uesp_url: string;
  esohub_url: string;
}

interface SkillData {
  id: string;
  name: string;
  base_skill?: string | null;
  morph_of?: string | null;
  morph_sibling?: string | null;
  morph_sibling_name?: string | null;
  morph_rationale?: string | null;
  class: string;
  skill_line: string;
  type: string;
  resource?: string;
  icon?: string;
}

interface RacePassive { name: string; description: string; }
interface RaceData {
  id: string;
  name: string;
  alliance: string;
  passives: RacePassive[];
  uesp_url: string;
}

interface CPStar { star: string; points: number; priority: number; }

interface TraitData  { id: string; name: string; category: string; effect?: string; value_range: string; }
interface EnchantData { id: string; name: string; category: string; rune_prefix: string; effect: string; }

interface GearItem {
  slot: string;
  type: string;
  item?: string;
  setId: string;
  setName?: string;
  tier: string;
  trait: string;
  enchant: string;
  traitData?: TraitData | null;
  enchantData?: EnchantData | null;
  barLabel?: string;
  weapon_type?: string;
}

// Consumable data shape (resolved from collection)
type ConsumableEffect =
  | { stat: string; value: number | string }
  | { description: string };

interface ConsumableData {
  id: string;
  name: string;
  type: string;
  patch_verified: string;
  uesp_url: string;
  effects: ConsumableEffect[];
  duration_seconds?: number;
  reagents?: string[];
  crafted: boolean;
}

interface ResolvedConsumable {
  data: ConsumableData | null;
  note?: string;
  alt?: string;
}

interface Props {
  title: string;
  class: string;
  role: string;
  resource: string;
  gamemode: string;
  patch: string;
  author: string;
  publishedDate?: string;
  updatedAt?: string;
  difficulty: string;
  summary: string;
  pullquote?: string;
  sets: SetData[];
  bar1: SkillData[];
  bar2: SkillData[];
  og_image?: string;
  gear?: {
    armor:   GearItem[];
    jewelry: GearItem[];
    weapons: GearItem[];
  };
  stats?: {
    health:  { target: number; note: string };
    magicka: { target: number; note: string };
    stamina: { target: number; note: string };
  };
  champion_points?: {
    warfare: CPStar[];
    fitness: CPStar[];
  };
  consumables?: {
    food?:   ResolvedConsumable;
    potion?: ResolvedConsumable;
    poison?: ResolvedConsumable;
    mundus?: { stone: string; effect?: string; note?: string; alt?: { stone: string; effect?: string; note?: string } };
  };
  playstyle?: {
    buffs?: { skill: string; stat: string; note: string; uptime: 'full' | 'high' | 'situational' }[];
    combo?: { skill: string; skill_alt?: string; role: string }[];
    rules?: { title: string; body: string }[];
  };
  race?: RaceData | null;
}

const {
  title, class: esClass, role, resource, gamemode,
  patch, author, publishedDate, updatedAt, difficulty, summary, pullquote,
  sets, bar1, bar2, og_image, gear, stats, champion_points, consumables, playstyle, race,
} = Astro.props;

const cpEffectMap = new Map<string, string>();
for (const star of [...cpStarsIndex.warfare, ...cpStarsIndex.fitness]) {
  cpEffectMap.set(star.name, star.effect);
}

function formatDate(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const subtitle = `${resource} ${esClass} ${gamemode} Build`;
const h1Text   = `${title} — ${subtitle}`;

const siteUrl        = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://kozy-eso-pvp-builds.simbad14100.workers.dev';
const canonical      = new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbs     = og_image
  ? (og_image.startsWith('http') ? og_image : `${siteUrl}${og_image}`)
  : `${siteUrl}/assets/og/og-default.png`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1Text,
  description: summary,
  image: ogImageAbs,
  datePublished: publishedDate ?? updatedAt ?? null,
  dateModified: updatedAt ?? publishedDate ?? null,
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'Kozy ESO PvP Builds',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  mainEntityOfPage: canonical,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: siteUrl + '/' },
    { '@type': 'ListItem', position: 2, name: 'Builds', item: siteUrl + '/builds/' },
    { '@type': 'ListItem', position: 3, name: title,    item: canonical },
  ],
};

const hasPlaystyle = !!(
  playstyle && (
    playstyle.buffs?.length ||
    playstyle.combo?.length ||
    playstyle.rules?.length
  )
);

// Compute active pieces per set from gear data
const activePiecesMap = new Map<string, number>();
if (gear) {
  for (const item of [...gear.armor, ...gear.jewelry, ...gear.weapons]) {
    activePiecesMap.set(item.setId, (activePiecesMap.get(item.setId) ?? 0) + 1);
  }
}

// Set name lookup for gear sheet
const setNameById = Object.fromEntries(sets.map(s => [s.id, s.name]));
function setLabel(setId: string): string {
  return setNameById[setId] ?? setId;
}

const railItems = [`KOZY · ESO PvP`];
---

<Base title={`${title} — ${resource} ${esClass} PvP Build | ESO ${patch}`} description={summary} ogImage={og_image} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <!-- MASTHEAD -->
  <header class="masthead">
    <div class="masthead__rail">
      {railItems.map((item, i) => (
        <>
          {i > 0 && <span class="masthead__rail-sep" aria-hidden="true">·</span>}
          <span>{item}</span>
        </>
      ))}
    </div>

    <div class="masthead__title">
      <div class="masthead__sigil">
        <svg width="72" height="72" viewBox="0 0 64 64" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="sg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#c4b5fd" stop-opacity="0.9"/>
              <stop offset="1" stop-color="#6d28d9" stop-opacity="0.4"/>
            </linearGradient>
          </defs>
          <g fill="none" stroke="url(#sg)" stroke-width="1.2">
            <rect x="14" y="14" width="36" height="36" transform="rotate(45 32 32)"/>
            <rect x="20" y="20" width="24" height="24" transform="rotate(45 32 32)"/>
            <circle cx="32" cy="32" r="3.2" fill="#8b5cf6" stroke="none"/>
            <line x1="32" y1="6" x2="32" y2="58"/>
            <line x1="6" y1="32" x2="58" y2="32"/>
          </g>
        </svg>
      </div>

      <h1 class="kz-display kz-display--l">{h1Text}</h1>
      <p class="masthead__dates">
        <span class="masthead__author">By {author}</span>
        {(publishedDate || updatedAt) && (
          <>
            <span class="masthead__dates-sep" aria-hidden="true"> · </span>
            <span>
              {publishedDate
                ? (updatedAt && updatedAt !== publishedDate
                    ? `Published ${formatDate(publishedDate)} · Updated ${formatDate(updatedAt)}`
                    : `Published ${formatDate(publishedDate)}`)
                : `Updated ${formatDate(updatedAt!)}`
              }
            </span>
          </>
        )}
        <span class="masthead__dates-sep" aria-hidden="true"> · </span>
        <span>Patch {patch}</span>
      </p>
    </div>

    <div class={`masthead__meta ${race ? 'masthead__meta--7' : 'masthead__meta--6'}`}>
      <div class="kz-meta"><div class="kz-meta__label">Class</div><div class="kz-meta__value">{esClass}</div></div>
      <div class="kz-meta"><div class="kz-meta__label">Role</div><div class="kz-meta__value">{role}</div></div>
      <div class="kz-meta"><div class="kz-meta__label">Resource</div><div class="kz-meta__value">{resource}</div></div>
      <div class="kz-meta"><div class="kz-meta__label">Gamemode</div><div class="kz-meta__value">{gamemode}</div></div>
      <div class="kz-meta"><div class="kz-meta__label">Patch</div><div class="kz-meta__value">{patch}</div></div>
      <div class="kz-meta"><div class="kz-meta__label">Difficulty</div><div class="kz-meta__value kz-meta__value--small">{difficulty}</div></div>
      {race && <div class="kz-meta"><div class="kz-meta__label">Race</div><div class="kz-meta__value kz-meta__value--small">{race.name}</div></div>}
    </div>
  </header>

  <!-- TWO-COLUMN LAYOUT -->
  <div class="build-layout">
  <div class="build-content">

  <!-- OVERVIEW -->
  <section id="overview">
  <div class="kz-rule" role="separator">
    <span class="kz-rule__line"></span>
    <span class="kz-rule__label">Overview</span>
    <span class="kz-rule__line"></span>
  </div>

  <div class="briefing__grid">
    <div class="briefing__lede">
      <p class="briefing__p">{summary}</p>
    </div>

    {pullquote && (
      <aside class="pullquote">
        <span class="pullquote__mark" aria-hidden="true">"</span>
        <p>{pullquote}</p>
      </aside>
    )}

    {stats && (
      <div class="briefing__stats">
        <div class="kz-stat">
          <div class="kz-stat__k">HP</div>
          {stats.health.target != null && <div class="kz-stat__v">{stats.health.target.toLocaleString()}</div>}
          {stats.health.note && <div class="kz-stat__note">{stats.health.note}</div>}
        </div>
        <div class="kz-stat">
          <div class="kz-stat__k">MAG</div>
          {stats.magicka.target != null && <div class="kz-stat__v">{stats.magicka.target.toLocaleString()}</div>}
          {stats.magicka.note && <div class="kz-stat__note">{stats.magicka.note}</div>}
        </div>
        <div class="kz-stat">
          <div class="kz-stat__k">STA</div>
          {stats.stamina.target != null && <div class="kz-stat__v">{stats.stamina.target.toLocaleString()}</div>}
          {stats.stamina.note && <div class="kz-stat__note">{stats.stamina.note}</div>}
        </div>
      </div>
    )}
  </div>

  </section>

  <!-- RACE -->
  {race && (
    <section id="race">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Race</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="race-card">
        <div class="race-card__header">
          <div>
            <span class="race-card__name">{race.name}</span>
            <span class="race-card__alliance">{race.alliance}</span>
          </div>
          <a class="race-card__uesp" href={race.uesp_url} target="_blank" rel="noopener noreferrer">UESP ↗</a>
        </div>
        <div class="race-card__passives">
          {race.passives.map(p => (
            <div class="race-passive">
              <span class="race-passive__name">{p.name}</span>
              <span class="race-passive__desc">{p.description}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SKILL BARS -->
  <section id="skill-bars">
  <div class="kz-rule" role="separator">
    <span class="kz-rule__line"></span>
    <span class="kz-rule__label">Skill Bars</span>
    <span class="kz-rule__line"></span>
  </div>

  <SkillBar bar1Skills={bar1} bar2Skills={bar2} />
  </section>

  <!-- PLAYSTYLE -->
  {hasPlaystyle && (
    <section id="playstyle">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Playstyle</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="prose">
        <Playstyle buffs={playstyle!.buffs} combo={playstyle!.combo} rules={playstyle!.rules} />
      </div>{/* /.prose */}
    </section>
  )}

  <!-- GEAR LOGIC -->
  <section id="set-choices">
  <div class="kz-rule" role="separator">
    <span class="kz-rule__line"></span>
    <span class="kz-rule__label">Set Choices</span>
    <span class="kz-rule__line"></span>
  </div>

  <div class="sets__grid">
    {sets.map((set, i) => (
      <SetCard
        id={set.id}
        index={i + 1}
        name={set.name}
        type={set.type}
        acquisition={set.acquisition}
        location={set.location}
        dlc={set.dlc}
        pieces={set.pieces}
        bonuses={set.bonuses}
        activePieces={activePiecesMap.get(set.id) ?? set.pieces}
        uesp_url={set.uesp_url}
        esohub_url={set.esohub_url}
      />
    ))}
  </div>

  </section>

  <!-- GEAR SHEET -->
  {gear && (
    <section id="gear-sheet">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Gear Sheet · Slot Assignments</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="gear__legend" aria-label="Armor weight color legend">
        <span class="gear__legend-item gear__legend-item--heavy">Heavy</span>
        <span class="gear__legend-item gear__legend-item--medium">Medium</span>
        <span class="gear__legend-item gear__legend-item--light">Light</span>
      </div>

      <div class="gear__cols">
        <!-- Armor -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Armor</span>
            <span class="gear__hd-count">{gear.armor.length} pieces</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.armor.map(row => (
                <tr class={`gr gr--${row.type}`}>
                  <td class="gr__slot"><span class="gr__pin" aria-hidden="true"></span>{row.slot}</td>
                  <td class="gr__item">
                    <span class="gr__name">{row.setName ?? row.setId}</span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Jewelry -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Jewelry</span>
            <span class="gear__hd-count">{gear.jewelry.length} pieces</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.jewelry.map(row => (
                <tr class={`gr gr--${row.type}`}>
                  <td class="gr__slot"><span class="gr__pin" aria-hidden="true"></span>{row.slot}</td>
                  <td class="gr__item">
                    <span class="gr__name">{row.setName ?? row.setId}</span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Weapons -->
        <div class="gear__section">
          <div class="gear__hd">
            <span class="gear__hd-title">Weapons</span>
            <span class="gear__hd-count">2 bars · {gear.weapons.length} weapons</span>
          </div>
          <table class="gear__tbl">
            <thead>
              <tr><th>Slot</th><th>Item</th><th>Trait</th><th>Enchantment</th></tr>
            </thead>
            <tbody>
              {gear.weapons.map(row => (
                <tr class="gr gr--weapon">
                  <td class="gr__slot">
                    <span class="gr__pin" aria-hidden="true"></span>
                    {row.slot}
                    <span class="gr__bar">{row.barLabel}</span>
                    {row.weapon_type && <span class="gr__wtype">{row.weapon_type}</span>}
                  </td>
                  <td class="gr__item">
                    <span class="gr__name">{row.setName ?? row.setId}</span>
                  </td>
                  <td class="gr__trait">
                    {row.traitData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.traitData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">
                          {row.traitData.effect && <span class="gr__tip-effect">{row.traitData.effect}</span>}
                          <span class="gr__tip-range">{row.traitData.value_range}</span>
                        </span>
                      </span>
                    ) : row.trait}
                  </td>
                  <td class="gr__ench">
                    {row.enchantData ? (
                      <span class="gr__meta-wrap">
                        <span class="gr__meta-name">{row.enchantData.name}</span>
                        <span class="gr__meta-tip" role="tooltip">{row.enchantData.effect}</span>
                      </span>
                    ) : row.enchant}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- CONSUMABLES -->
  {consumables && (
    <section id="consumables">
      <div class="kz-rule" role="separator">
        <span class="kz-rule__line"></span>
        <span class="kz-rule__label">Consumables</span>
        <span class="kz-rule__line"></span>
      </div>

      <div class="supplies__grid">
        {/* ── Food ── */}
        {consumables.food?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Food</div>
            <h4 class="supply-card__name">{consumables.food.data.name}</h4>
            {/* Stat effects (food/drink: { stat, value } objects) */}
            <ul class="supply-card__effects">
              {consumables.food.data.effects.map(fx => (
                'stat' in fx
                  ? <li><span class="supply-card__fx-stat">{fx.stat}</span><span class="supply-card__fx-val">{fx.value.toLocaleString()}</span></li>
                  : <li class="supply-card__fx-desc">{fx.description}</li>
              ))}
            </ul>
            {consumables.food.data.duration_seconds && (
              <p class="supply-card__meta">
                Duration · {consumables.food.data.duration_seconds >= 3600
                  ? `${consumables.food.data.duration_seconds / 3600}h`
                  : `${Math.round(consumables.food.data.duration_seconds / 60)}m`}
              </p>
            )}
            {consumables.food.note && <p class="supply-card__note">{consumables.food.note}</p>}
            {consumables.food.alt && <p class="supply-card__alt">Alt · {consumables.food.alt}</p>}
          </div>
        )}

        {/* ── Potion ── */}
        {consumables.potion?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Potion</div>
            <h4 class="supply-card__name">{consumables.potion.data.name}</h4>
            {consumables.potion.data.effects.map(fx => (
              'description' in fx
                ? <p class="supply-card__body">{fx.description}</p>
                : <p class="supply-card__body">{fx.stat} · {fx.value}</p>
            ))}
            {consumables.potion.data.reagents && consumables.potion.data.reagents.length > 0 && (
              <ul class="supply-card__ingredients">
                {consumables.potion.data.reagents.map(r => <li>{r}</li>)}
              </ul>
            )}
            {consumables.potion.note && <p class="supply-card__note">{consumables.potion.note}</p>}
          </div>
        )}

        {/* ── Poison ── */}
        {consumables.poison?.data && (
          <div class="supply-card">
            <div class="supply-card__kicker">Poison</div>
            <h4 class="supply-card__name">{consumables.poison.data.name}</h4>
            {consumables.poison.data.effects.map(fx => (
              'description' in fx
                ? <p class="supply-card__body">{fx.description}</p>
                : <p class="supply-card__body">{fx.stat} · {fx.value}</p>
            ))}
            {consumables.poison.data.reagents && consumables.poison.data.reagents.length > 0 && (
              <ul class="supply-card__ingredients">
                {consumables.poison.data.reagents.map(r => <li>{r}</li>)}
              </ul>
            )}
            {consumables.poison.note && <p class="supply-card__note">{consumables.poison.note}</p>}
          </div>
        )}

        {/* ── Mundus (text-based, not yet a collection) ── */}
        {consumables.mundus && (
          <div class="supply-card supply-card--mundus">
            <div class="supply-card__kicker">Mundus Stone</div>
            <h4 class="supply-card__name">{consumables.mundus.stone}</h4>
            {consumables.mundus.effect && <p class="supply-card__body">{consumables.mundus.effect}</p>}
