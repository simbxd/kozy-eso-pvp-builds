{
  "name": "kozy-eso-pvp-builds",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/rename-sitemap.mjs",
    "sync": "git pull --ff-only origin main && npm run build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch:eso": "node scripts/fetch-eso-data.mjs",
    "fetch:icons": "node scripts/fetch-skill-icons.mjs",
    "gen:decap": "node scripts/gen-decap-config.mjs",
    "gen:decap:local": "node scripts/gen-decap-config.mjs --local",
    "gen:og": "node scripts/gen-og-image.mjs",
    "update:decap": "npm run fetch:eso && npm run gen:decap",
    "test": "node --test tests/*.test.mjs",
    "migrate:skill-line-id": "node scripts/migrate-add-skill-line-id.mjs",
    "fetch:meta": "node scripts/fetch-eso-meta.mjs",
    "fetch:consumables": "node scripts/fetch-consumables.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cheerio": "^1.2.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "vite": "^7.0.0",
    "wrangler": "^4.93.1"
  }
}
